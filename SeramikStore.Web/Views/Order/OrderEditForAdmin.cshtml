@using Microsoft.Extensions.Localization
@using SeramikStore.Web.Localization
@using SeramikStore.Contracts.Order
@using System.Globalization
@model OrderDetailedDto
@inject IStringLocalizer<CartResource> L

@{
    ViewData["Title"] = L["Sipariş Detayı"];
    var culture = CultureInfo.CurrentCulture;
    var currency = Model.CurrencyCode?.ToUpper();
}

<div class="container mt-4">
    <div class="row">

        <!-- SOL TARAF (GENİŞ) -->
        <div class="col-md-8">

            <!-- SİPARİŞ BİLGİ KARTI -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">

                    <div class="row small">
                        <div class="col-6 mb-2">
                            <strong>@L["Sipariş No"]: #@Model.Id</strong>
                        </div>
                        <div class="col-6 mb-2 text-md-end">
                            <strong>@L["Sipariş Tarihi"]:</strong>
                            @Model.OrderDate.ToString("dd.MM.yyyy HH:mm")
                        </div>
                        <div class="col-6">
                            <strong>@L["Durum"]:</strong>
                            <span class="badge bg-secondary">@Model.OrderStatus</span>
                        </div>
                        <div class="col-6 text-md-end">
                            <strong>@L["Kargo Firması"]:</strong>
                            @(string.IsNullOrEmpty(Model.KargoSirketi)
                                                        ? L["Henüz Belirlenmedi"]
                                                        : Model.KargoSirketi)
                        </div>

                    </div>


                </div>
            </div>
            <!-- KARGO TAKİP -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">

                    <h6 class="mb-3">
                        <i class="fa-solid fa-box me-2"></i>
                        @L["Kargo Bilgisi"]
                    </h6>

                    @if (!string.IsNullOrEmpty(Model.KargoTakipNo))
                    {
                        <div class="small">
                            <p class="mb-1">
                                <strong>@L["Kargoya Verilme Tarihi"]:</strong>
                                @Model.KargoyaVerilmeTarihi?.ToString("dd.MM.yyyy")
                            </p>
                            <p class="mb-0">
                                <strong>@L["Takip No"]:</strong>
                                @Model.KargoTakipNo
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">
                            @L["Siparişiniz henüz kargoya verilmedi."]
                        </div>
                    }

                </div>
            </div>



            <!-- TESLİMAT ADRESİ -->
            <div class="card shadow-sm mb-4">
                <div class="card-body">

                    <h6 class="mb-3">
                        <i class="fa-solid fa-truck me-2"></i>
                        @L["Teslimat Adresi"]
                    </h6>

                    @if (Model.Address != null)
                    {
                        <div class="border rounded-3 p-3 bg-light">
                            <strong>@Model.Address.Ad @Model.Address.Soyad</strong><br />
                            @Model.Address.Adres<br />
                            @Model.Address.Ilce / @Model.Address.Il<br />
                            @Model.Address.Telefon
                        </div>
                    }

                </div>
            </div>

            <!-- ÜRÜN LİSTESİ -->
            <div class="card shadow-sm">
                <div class="card-body">

                    <h6 class="mb-3">
                        <i class="fa-solid fa-cart-shopping me-2"></i>
                        @L["Sipariş Ürünleri"]
                    </h6>

                    <div class="table-responsive">
                        <table class="table align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>@L["Ürün"]</th>
                                    <th class="text-end">@L["Birim Fiyat"]</th>
                                    <th class="text-center">@L["Miktar"]</th>
                                    <th class="text-end">@L["Tutar"]</th>
                                </tr>
                            </thead>
                            <tbody>

                                @foreach (var item in Model.Items)
                                {
                                    <tr>
                                        <td>@item.ProductName</td>
                                        <td class="text-end">
                                            @item.UnitPrice.ToString("N2", culture) @currency
                                        </td>
                                        <td class="text-center">
                                            @item.Quantity @L["Adet"]
                                        </td>
                                        <td class="text-end">
                                            @item.LineTotal.ToString("N2", culture) @currency
                                        </td>
                                    </tr>
                                }

                                <tr>
                                    <th></th>
                                    <th></th>
                                    <th class="text-end fw-bold">@L["Ürün Toplamı"]</th>
                                    <th class="text-end">
                                        @Model.ProductTotal.ToString("N2", culture) @currency
                                    </th>
                                </tr>

                                <tr>
                                    <th></th>
                                    <th></th>
                                    <th class="text-end fw-bold">@L["Kargo Tutarı"]</th>
                                    <th class="text-end">
                                        @Model.CargoAmount.ToString("N2", culture) @currency
                                    </th>
                                </tr>

                                <tr>
                                    <th></th>
                                    <th></th>
                                    <th class="text-end fw-bold">@L["Genel Toplam"]</th>
                                    <th class="text-end fw-bold">
                                        @Model.GrandTotal.ToString("N2", culture) @currency
                                    </th>
                                </tr>

                            </tbody>
                        </table>
                    </div>

                </div>
            </div>

        </div>

        <!-- SAĞ TARAF (DAR) -->
        <div class="col-md-4">

            <!-- STATÜ GÜNCELLE -->
            <div class="card shadow-sm mb-4 border-warning">
                <div class="card-body">

                    <h6 class="mb-3 text-warning fw-bold">
                        <i class="fa-solid fa-pen-to-square me-2"></i>
                        @L["Statü Güncelle"]
                    </h6>

                    <!-- Güncelle Form -->
                    <form asp-action="UpdateStatus" method="post" class="mb-3">
                        <input type="hidden" name="orderId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label small text-muted">
                                @L["Mevcut Statü"]
                            </label>
                            <span class="badge bg-secondary">@Model.OrderStatus</span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small text-muted">
                                @L["Yeni Statü"]
                            </label>
                            <select name="selectedStatus" class="form-select form-select-sm">
                                @foreach (var item in Model.NextStatusesForUpdate)
                                {
                                    <option value="@item.OrderStatusCode">
                                        @item.OrderStatusCode - @item.Aciklama
                                    </option>
                                }
                            </select>
                        </div>

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-warning btn-sm px-4">
                                @L["Güncelle"]
                            </button>
                        </div>
                    </form>

                    @if (Model.OrderStatusCode < 60)
                    {
                        <hr />

                        <!-- İPTAL FORM -->
                        <form asp-action="CancelOrder" method="post"
                              onsubmit="return confirm('@L["Siparişi iptal etmek istediğinize emin misiniz?"]');">

                            <input type="hidden" name="orderId" value="@Model.Id" />

                            <div class="d-flex justify-content-end">
                                <button type="submit" class="btn btn-outline-danger btn-sm">
                                    <i class="fa-solid fa-ban me-1"></i>
                                    @L["Siparişi İptal Et"]
                                </button>
                            </div>
                        </form>
                    }

                </div>
            </div>

            <!-- ALT BUTONLAR -->
            <div class="d-grid gap-2 mb-4">
                <a asp-controller="Home"
                   asp-action="Index"
                   class="btn btn-outline-primary btn-sm">
                    @L["Ana Sayfaya Dön"]
                </a>

                <a asp-controller="Order"
                   asp-action="CustomerOrders"
                   class="btn btn-primary btn-sm">
                    @L["Müşteri Siparişleri"]
                </a>
            </div>

            <!-- DURUM GEÇMİŞİ -->

            <div class="card shadow-sm">
                <div class="card-body">

                    <h6 class="mb-4">
                        <i class="fa-solid fa-chart-line me-2"></i>
                        @L["Sipariş Süreci"]
                    </h6>

                    @{
                        var allStatuses = Model.AllStatuses; // Tüm statü listesi (10-80)
                        var history = Model.StatusHistory.ToList();
                        var completedCodes = history.Select(x => x.OrderStatusCode).ToList();
                        var currentCode = Model.OrderStatusCode;
                    }

                    <div class="card shadow-sm mb-4">
                        <div class="card-body">

                            <h6 class="mb-4">
                                <i class="fa-solid fa-chart-line me-2"></i>
                                @L["Sipariş Süreci"]
                            </h6>

                            @{
                                var allStatuses = Model.AllStatuses.OrderBy(x => x.OrderStatusCode).ToList();
                                var history = Model.StatusHistory.ToList();
                                var completedCodes = history.Select(x => x.OrderStatusCode).ToList();
                                var currentCode = Model.OrderStatusCode;
                            }

                            <div class="stepper-wrapper">

                                @for (int i = 0; i < allStatuses.Count; i++)
                                {
                                    var status = allStatuses[i];
                                    var isCompleted = completedCodes.Contains(status.OrderStatusCode);
                                    var isCurrent = status.OrderStatusCode == currentCode;
                                    var historyItem = history.FirstOrDefault(x => x.OrderStatusCode == status.OrderStatusCode);

                                    <div class="stepper-item @(isCompleted ? "completed" : "") @(isCurrent ? "active" : "")">

                                        <div class="step-counter">
                                            @if (isCompleted)
                                            {
                                                <i class="fa-solid fa-check"></i>
                                            }
                                            else
                                            {
                                                <i class="fa-regular fa-circle"></i>
                                            }
                                        </div>

                                        <div class="step-name">
                                            @status.Aciklama

                                            @if (historyItem != null)
                                            {
                                                <div class="step-date">
                                                    @historyItem.IslemTarihi.ToString("dd.MM HH:mm")
                                                </div>
                                            }
                                        </div>

                                    </div>
                                }

                            </div>

                        </div>
                    </div>

                </div>
            </div>
            <div class="card shadow-sm">
                <div class="card-body">
                    <h6 class="mb-3">
                        <i class="fa-solid fa-clock-rotate-left me-2"></i>
                        @L["Durum Geçmişi"]
                    </h6>

                    @foreach (var shistory in Model.StatusHistory)
                    {
                        <div class="small mb-3 pb-2 border-bottom">
                            <div class="fw-semibold">@shistory.Aciklama</div>
                            <div class="text-muted">
                                @shistory.IslemTarihi.ToString("dd.MM.yyyy HH:mm")
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>

    </div>
</div>


