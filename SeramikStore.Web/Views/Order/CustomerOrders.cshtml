@using Microsoft.Extensions.Localization
@using SeramikStore.Contracts.Order
@using SeramikStore.Web.Localization
@using System.Globalization
@model List<OrderAdminListItemDto>
@inject IStringLocalizer<CartResource> L

@{
    ViewData["Title"] = L["Müşteri Siparişleri"];
    var culture = CultureInfo.CurrentCulture;
}
<div class="mt-3 d-flex gap-2">
    <a asp-controller="Order" asp-action="CustomerOrders" class="btn btn-outline-primary">
        <i class="bi bi-arrow-clockwise me-1"></i> Yenile
    </a>
</div>
<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">

            <h6 class="mb-4 d-flex align-items-center gap-2">
                <i class="fa-solid fa-users me-1"></i>
                @L["Müşteri Siparişleri"]
                <span class="badge bg-secondary fw-normal">@Model.Count @L["Sipariş"]</span>
            </h6>

            @* MASAÜSTÜ TABLO - md ve üzeri *@
            <div class="d-none d-md-block table-responsive">
                <table class="table align-middle table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>@L["Sipariş No"]</th>
                            <th>@L["Sipariş Tarihi"]</th>
                            <th>@L["Müşteri"]</th>
                            <th>@L["E-Posta"]</th>
                            <th class="text-end">@L["Toplam Tutar"]</th>
                            <th>@L["Sipariş Durumu"]</th>
                            <th class="text-end">@L["Güncelle"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr id="order-@item.Id">
                                <td><span class="text-muted">#</span>@item.Id</td>
                                <td class="small">@item.OrderDate.ToString("dd.MM.yyyy HH:mm", culture)</td>
                                <td>@item.FirstName @item.LastName</td>
                                <td class="small text-muted">@item.Email</td>
                                <td class="text-end fw-semibold">
                                    @item.GrandTotal.ToString("N2", culture)
                                    <small class="text-muted">@item.CurrencyCode</small>
                                </td>
                                <td>
                                    <span class="badge bg-secondary">@L[item.OrderStatus]</span>
                                </td>
                                <td class="text-end">
                                    <a asp-controller="Order"
                                       asp-action="OrderEditForAdmin"
                                       asp-route-id="@item.Id"
                                       class="btn btn-sm btn-outline-dark">
                                        <i class="fa-solid fa-edit"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* MOBİL KARTLAR - md altı *@
            <div class="d-md-none">
                @foreach (var item in Model)
                {
                    <div class="card mb-2 border" id="order-@item.Id">
                        <div class="card-body p-3">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <span class="fw-semibold">#@item.Id</span>
                                    <span class="badge bg-secondary ms-2">@L[item.OrderStatus]</span>
                                </div>
                                <a asp-controller="Order"
                                   asp-action="OrderEditForAdmin"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-dark">
                                    <i class="fa-solid fa-edit"></i>
                                </a>
                            </div>
                            <p class="mb-1 fw-semibold">@item.FirstName @item.LastName</p>
                            <p class="mb-1 small text-muted">@item.Email</p>
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <small class="text-muted">@item.OrderDate.ToString("dd.MM.yyyy HH:mm", culture)</small>
                                <span class="fw-semibold">
                                    @item.GrandTotal.ToString("N2", culture)
                                    <small class="text-muted">@item.CurrencyCode</small>
                                </span>
                            </div>
                        </div>
                    </div>
                }
            </div>


        </div>
    </div>
</div>

<script>
    const params = new URLSearchParams(window.location.search);
    const highlightId = params.get("highlightId");

    if (highlightId) {
        const row = document.getElementById("order-" + highlightId);
        if (row) {
            row.scrollIntoView({ behavior: "smooth", block: "center" });
            row.classList.add("table-warning");
            setTimeout(() => row.classList.remove("table-warning"), 6000);
        }
    }
</script>