@using Microsoft.Extensions.Localization
@using SeramikStore.Contracts.Return
@using SeramikStore.Web.Localization
@using SeramikStore.Contracts.Order
@using System.Globalization
@using SeramikStore.Entities.Enums
@model OrderDetailedDto
@inject IStringLocalizer<CartResource> L

@{
    ViewData["Title"] = L["Sipariş Detayı"];
    var culture = CultureInfo.CurrentCulture;
    var currency = Model.CurrencyCode?.ToUpper();

    List<ReturnHeaderDto> TheReturnList = Model.returnList.Headers;
}
<div class="container mt-4">
    <div class="row">
        <!-- SOL TARAF (DAR) -->
        <div class="col-md-2">
            <partial name="_LeftMenu" />
        </div>
        <!-- ORTA TARAF (GENİŞ) -->
        <div class="col-md-7">
            <!-- SİPARİŞ SÜRECİ -->
            <div class="card shadow-sm mb-1">
                <div class="card-body">

                    <h6 class="mb-2">
                        <i class="fa-solid fa-bars-progress me-2"></i>
                        @L["Sipariş Süreci"]
                    </h6>

                    @{
                        var ProcessStatuses = Model.StatusProcess.OrderBy(x => x.RowOrderNo).ToList();
                        var currentCode = Model.OrderStatusCode;
                        var isCancelled = currentCode == (int)OrderStatusCode.Cancelled;
                    }
                    @if (isCancelled)
                    {
                        <div class="alert alert-danger text-center fw-bold mb-4">
                            @L["Sipariş İptal Edildi"]
                        </div>
                    }
                    <div class="stepper-wrapper">


                        @for (int i = 0; i < ProcessStatuses.Count; i++)
                        {
                            var ProcessStatusItem = ProcessStatuses[i];
                            var isCompleted = ProcessStatusItem.isCompleted;
                            var isCurrent = ProcessStatusItem.isLast;
                            var isLastCancelledStep = (ProcessStatusItem.OrderStatusCode == (int)OrderStatusCode.Cancelled);

                            @if (isCancelled && (isCompleted == false))
                            {

                            }
                            else
                            {
                                <div class="stepper-item @(isCompleted ? "completed" : "") @(isCurrent ? "active" : "") @(isLastCancelledStep ? "iptal" : "")">

                                    <div class="step-counter">
                                        @if (isCompleted)
                                        {
                                            <i class="fa-solid fa-check"></i>
                                        }
                                        else
                                        {
                                            @if (isCancelled)
                                            {
                                                <i class="fa-solid fa-cancel"></i>
                                            }
                                            else
                                            {


                                            }

                                        }

                                    </div>

                                    <div class="step-name">

                                        @L[ProcessStatusItem.Aciklama]

                                        @if (isCompleted)
                                        {
                                            <div class="step-date">
                                                @(ProcessStatusItem?.IslemTarihi?.ToString("dd.MM.yyyy HH:mm") ?? "-")
                                            </div>
                                        }

                                    </div>

                                </div>
                            }


                        }

                    </div>

                </div>
            </div>
           <!-- TESLİMAT ADRESİ -->
            <div class="card shadow-sm mb-1">
                <div class="card-body">
                    <h6 class="mb-1">
                    <span class="d-flex align-items-center justify-content-between w-100"
                          data-bs-toggle="collapse"
                          href="#TeslimatAdresiCollapse"
                          role="button">

                        <!-- SOL: icon + text -->
                        <span class="d-flex align-items-center">
                                <i class="fa-solid fa-truck me-2"></i>
                            @L["Teslimat Adresi"]
                         </span>
                        <!-- SAĞ: ok -->
                        <i id="arrowIconT" class="fa-solid fa-chevron-down transition"></i>
                       
                    </span>
                    </h6>
                    <div class="collapse" id="TeslimatAdresiCollapse">
                    @if (Model.Address != null)
                    {
                        <div class="border rounded-3 p-3 bg-light">
                            <strong>@Model.Address.Ad @Model.Address.Soyad</strong><br />
                            @Model.Address.Adres<br />
                            @Model.Address.Ilce / @Model.Address.Il<br />
                            @Model.Address.Telefon
                        </div>
                    }
                    </div>
                </div>
            </div>
            <!-- SİPARİŞ ÜRÜNLERİ -->
            <div class="card shadow-sm mb-1">
                <div class="card-body">
                    <h6 class="mb-1">
                        <span class="d-flex align-items-center justify-content-between w-100"
                              data-bs-toggle="collapse"
                              href="#orderItemsCollapse"
                              role="button">

                            <!-- SOL: icon + text -->
                            <span class="d-flex align-items-center">
                                <i class="fa-solid fa-list me-2"></i>
                                @L["Sipariş Ürünleri"]
                            </span>

                            <!-- SAĞ: ok -->
                            <i id="arrowIconS" class="fa-solid fa-chevron-down transition"></i>

                        </span>
                    </h6>
                    <div class="collapse" id="orderItemsCollapse">
                        <div class="table-responsive">
                            <table class="table align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>@L["Ürün"]</th>
                                        <th class="text-end">@L["Birim Fiyat"]</th>
                                        <th class="text-center">@L["Miktar"]</th>
                                        <th class="text-end">@L["Tutar"]</th>
                                    </tr>
                                </thead>
                                <tbody>

                                    @foreach (var item in Model.Items)
                                    {
                                        <tr>
                                            <td>
                                                <div class="product-cell">
                                                    <div class="product-img">
                                                        <img src="@(string.IsNullOrEmpty(item.ImageThumbPath) ? "/images/no-image.png" : item.ImageThumbPath)"
                                                                alt="@item.ProductName">
                                                    </div>
                                                    <div class="product-info">
                                                        <div class="product-code">@item.ProductCode</div>
                                                        <div class="product-name">@item.ProductName</div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-end">
                                                @item.UnitPrice.ToString("N2", culture) @currency
                                            </td>
                                            <td class="text-center">
                                                @item.Quantity @L["Adet"]
                                            </td>
                                            <td class="text-end">
                                                @item.LineTotal.ToString("N2", culture) @currency
                                            </td>
                                        </tr>
                                    }


                                    <tr class="border-white">
                                        <td colspan="2" class="text-end fw-semibold py-0">@L["Ürün Toplamı"]</td>
                                        <td colspan="2" class="text-end fw-semibold py-0">@Model.ProductTotal.ToString("N2", culture) @currency</td>
                                    </tr>

                                    <tr class="border-white">
                                        <td colspan="2" class="text-end fw-semibold py-0">@L["Kargo Tutarı"]</td>
                                        <td colspan="2" class="text-end fw-semibold py-0">@Model.CargoAmount.ToString("N2", culture) @currency</td>
                                    </tr>

                                    <tr class="border-white">
                                        <td colspan="2" class="text-end fw-semibold py-0">@L["Genel Toplam"]</td>
                                        <td colspan="2" class="text-end fw-semibold py-0">@Model.GrandTotal.ToString("N2", culture) @currency</td>
                                    </tr>

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            

            <!-- İADE TALEPLERİ -->
            <div class="card shadow-sm mb-1">
                <div class="card-body">
                    
                    <h6 class="mb-1">
                        <span class="d-flex align-items-center justify-content-between w-100"
                              data-bs-toggle="collapse"
                              href="#ReturnListCollapse"
                              role="button">
                              
                            <!-- SOL: icon + text -->
                            <span class="d-flex align-items-center">
                                <i class="fa-solid fa-rotate-left me-2"></i>
                                @L["İade Talepleri"]
                            </span>

                            <!-- SAĞ: ok -->
                            <i id="arrowIconR" class="fa-solid fa-chevron-down transition"></i>

                        </span>
                    </h6>

                    <div class="@(TempData["LastReturnId"] != null ? "show" : "collapse")" id="ReturnListCollapse">
              
                            <div class="d-flex justify-content-end mb-4">
                            @if (@Model.ThisOrderIsReturnableByCustomer)
                            {
                                <a asp-controller="Return"
                                   asp-action="NewReturn"
                                   asp-route-Id="@Model.Id"
                                   class="btn btn-primary btn-sm">
                                    Yeni İade Talebi
                                </a>
                            }
                            </div>
                     

                    @foreach (var ret in TheReturnList)
                    {
                            <div class="card shadow-sm border-2 mb-4 rounded-4">
                                <div class="card-body p-4">
      
                                    <!-- HEADER -->
                                        <div class="d-flex justify-content-between align-items-start mb-3">

                                        <div class="fw-semibold d-flex align-items-center gap-2">
                                            Talep No:
                                            <span class="badge rounded-pill px-3 py-2 fw-medium bg-warning-subtle text-warning-emphasis" id="return-row-@ret.Id">@ret.Id</span>
                                            
                                            @if (ret.IsCancelable)
                                            {
                                                <form id="@string.Format("cancelReturnForm{0}", ret.Id)" asp-controller="Return" asp-action="CancelMyReturn" method="post">
                                                <input type="hidden" name="ReturnHeaderid" value="@ret.Id" />
                                                <input type="hidden" name="OrderId" value="@ret.OrderId" />
                                                <button type="button"
                                                        class="btn btn-outline-danger btn-sm"
                                                            onclick="showConfirm('@string.Format("{0} İade Talebi iptal edilecek. Emin misiniz?", ret.Id)', function() { document.getElementById('@string.Format("cancelReturnForm{0}", ret.Id)').submit(); });">
                                                    <i class="fa-solid fa-ban me-1"></i>
                                                    @L["İade Talebini İptal Et"]
                                                </button>
                                            </form> 

                                            }



                                        </div>

                                        <span class="badge rounded-pill px-3 py-2 fw-medium bg-warning-subtle text-warning-emphasis">
                                            <i class="bi bi-arrow-return-left me-1"></i>
                                            @L[ret.StatusForReturnDesc]
                                        </span>

                                    </div> 

                                    <!-- REASON -->
                                    <div class="mb-3">

                                        <div class="small text-muted mb-1">
                                            @ret.ReturnReason.Reasondesc
                                        </div>
                                        @if (ret.ManuelDescriptionForReason  != ""){
                                            <div class="bg-light rounded-3 p-3 small text-secondary">
                                                @ret.ManuelDescriptionForReason
                                            </div>
                                        }
                                    </div>

                                    <!-- DIVIDER -->
                                    <hr class="my-1" />

                                    <!-- PRODUCTS -->
                                    <div class="table-responsive">
                                        <table class="table align-middle mb-0">
                                            <thead class="text-muted small">
                                                <tr>
                                                    <th>@L["Ürün"]</th>
                                                    <th class="text-end">@L["Birim Fiyat"]</th>
                                                    <th class="text-center">@L["Miktar"]</th>
                                                    <th class="text-end">@L["Tutar"]</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in ret.Details)
                                                {
                                                    <tr class="border-top">
                                                        <td>
                                                            <div class="product-cell">
                                                                <div class="product-img">
                                                                    <img src="@(string.IsNullOrEmpty(item.ImagePath) ? "/images/no-image.png" : item.ImagePath)"
                                                                         alt="@item.ProductName">
                                                                </div>
                                                                <div class="product-info">
                                                                    <div class="product-code">@item.ProductCode</div>
                                                                    <div class="product-name">@item.ProductName</div>
                                                                </div>
                                                            </div>
                                                       
                                                        </td>

                                                        <td class="text-end">
                                                            @item.ReturnUnitPrice.ToString("N2") @item.CurrencyCode
                                                        </td>

                                                        <td class="text-center">
                                                            @item.ReturnQuantity  @L["Adet"]
                                                        </td>

                                                        <td class="text-end fw-semibold">
                                                            @item.ReturnLineTotal.ToString("N2") @item.CurrencyCode
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                            <tr class="border-white">
                                                <td colspan="2" class="text-end fw-semibold py-0">@L["Ürün Toplamı"]</td>
                                                <td colspan="2" class="text-end fw-semibold py-0">@ret.ReturnProductTotal.ToString("N2", culture) @currency</td>
                                            </tr>

                                            <tr class="border-white">
                                                <td colspan="2" class="text-end fw-semibold py-0">@L["Kargo Tutarı"]</td>
                                                <td colspan="2" class="text-end fw-semibold py-0">@ret.ReturnCargoAmount.ToString("N2", culture) @currency</td>
                                            </tr>

                                            <tr class="border-white">
                                                <td colspan="2" class="text-end fw-semibold py-0">@L["Geri Ödenecek Toplam"]</td>
                                                <td colspan="2" class="text-end fw-semibold py-0">@ret.ReturnGrandTotal.ToString("N2", culture) @currency</td>
                                            </tr>
                                        </table>
                                    </div>


                                    <div class="mb-3">
                                        <div class="small text-muted mb-1">
                                            @L["Banka"]: <span class="text-primary">@ret.BankName</span>
                                        </div>
                                         <div class="small text-muted mb-1">
                                            @L["IBAN"]: <span class="text-primary">@ret.IBAN</span>
                                        </div>
                                        <div class="small text-muted mb-1">
                                            @L["Hesap Sahibi"]: <span class="text-primary">@ret.AccountHolderName</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                    }
                    </div>

                </div>
            </div>

        </div>
        <!-- SAĞ TARAF (DAR) -->
        <div class="col-md-3">
            <div class="card shadow-sm mb-4 border-warning">
                <div class="card-body">
                    <!-- Sipariş No -->
                    <div class="row-cols-md-6">
                        <strong>@L["Sipariş No"]:</strong> #@Model.Id
                    </div>

                    <!-- Sipariş Tarihi -->
                    <div class="row-cols-md-6">
                        <strong>@L["Sipariş Tarihi"]:</strong>
                        @Model.OrderDate.ToString("dd.MM.yyyy HH:mm")
                    </div>
                    <!-- Sipariş Tarihi -->
                    @if (Model.DeliveryDate.HasValue)
                    {
                        <div class="row-md-6">
                            <strong>@L["Teslimat Tarihi"]:</strong>
                            @Model.DeliveryDate.Value.ToString("dd.MM.yyyy HH:mm")
                        </div>
                    }


                    @if (Model.ThisOrderCanBeCanceledByCustomer)
                    {
                        <hr />

                        <form id="cancelOrderForm" asp-action="CancelMyOrder" method="post">
                            <input type="hidden" name="orderId" value="@Model.Id" />

                            <button type="button"
                                    class="btn btn-outline-danger btn-sm"
                                    onclick="showConfirm('Siparişi iptal etmek istediğinize emin misiniz?', function() { document.getElementById('cancelOrderForm').submit(); });">
                                <i class="fa-solid fa-ban me-1"></i>
                                @L["Siparişi İptal Et"]
                            </button>
                        </form>
                    }

                </div>
            </div>
            <!-- ALT BUTONLAR -->
@*             <div class="d-grid gap-2 mb-4">
                <a asp-controller="Return"
                   asp-action="GetReturnsByOrderId"
                   asp-route-Id="@Model.Id"
                   class="btn btn-primary btn-sm">
                    @L["İade Taleplerim"]
                </a>
            </div> *@




        </div>
    </div>
</div>


<style>
    .cancelled-wrapper::before {
        background-color: #dc3545 !important;
    }

    .stepper-item.cancelled .step-counter {
        background-color: #dc3545;
        border-color: #dc3545;
        color: #fff;
    }

    .stepper-item.cancelled .step-name {
        color: #dc3545;
        font-weight: 700;
    }

    /* Eğer sipariş iptalse tüm çizgi kırmızı */
    .cancelled-wrapper .stepper-item.completed .step-counter {
        background-color: #dc3545;
        border-color: #dc3545;
    }


    .stepper-item.cancelled::after {
        background: repeating-linear-gradient( 45deg, #dc3545, #dc3545 5px, #ffffff 5px, #ffffff 10px );
    }

    .stepper-wrapper {
        display: flex;
        justify-content: space-between;
        position: relative;
        margin-top: 10px;
    }

        .stepper-wrapper::before {
            content: '';
            position: absolute;
            top: 18px;
            left: 0;
            right: 0;
            height: 3px;
            background-color: #dee2e6;
            z-index: 1;
        }

    .stepper-item {
        position: relative;
        text-align: center;
        flex: 1;
        z-index: 2;
    }

        .stepper-item:not(:last-child)::after {
            content: '';
            position: absolute;
            top: 18px;
            right: -50%;
            width: 100%;
            height: 3px;
            background-color: #dee2e6;
            z-index: -1;
        }

        .stepper-item.completed:not(:last-child)::after {
            background-color: #198754
        }

    .step-counter {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background-color: #fff;
        border: 3px solid #dee2e6;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 14px;
    }

    .stepper-item.completed .step-counter {
        background-color: #198754;
        border-color: #198754;
        color: #fff;
    }

    .stepper-item.active .step-counter {
        border-color: #ffc107;
        box-shadow: 0 0 0 4px rgba(255,193,7,.3);
    }

    .stepper-item.active.iptal .step-counter {
        border-color: #ffc107;
        background-color: red;
        box-shadow: 0 0 0 4px rgba(255,193,7,.3);
    }

    .step-name {
        margin-top: 8px;
        font-size: 13px;
        font-weight: 600;
    }

    .step-date {
        font-size: 11px;
        color: #6c757d;
        margin-top: 3px;
    }



    .product-cell {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .product-img {
        width: 60px;
        height: 60px;
        border-radius: 8px;
        overflow: hidden;
        background: #f8f9fa;
        flex-shrink: 0;
    }

        .product-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .product-name {
        font-weight: 600;
        font-size: 14px;
        line-height: 1.3;
    }

    .product-code {
        font-weight: 400;
        font-size: 13px;
        line-height: 1.3;
    }

    .table thead th {
        font-weight: 500; /* 400 = normal, 500 = medium (öneririm) */
        font-size: 13px; /* biraz küçültürsen daha zarif olur */
        color: #6c757d; /* hafif gri = daha soft görünüm */
    }

    /* mobil */
    @@media (max-width:768px) {
        .product-img {
            width: 50px;
            height: 50px;
        }

        .product-name {
            font-size: 13px;
        }
    }

</style>


<script>
    function handleCollapse(collapseId, iconId) {
        const collapse = document.getElementById(collapseId);
        const icon = document.getElementById(iconId);

        collapse.addEventListener('show.bs.collapse', function () {
            icon.classList.replace('fa-chevron-down', 'fa-chevron-up');
        });

        collapse.addEventListener('hide.bs.collapse', function () {
            icon.classList.replace('fa-chevron-up', 'fa-chevron-down');
        });
    }

    handleCollapse('orderItemsCollapse', 'arrowIconS');
    handleCollapse('ReturnListCollapse', 'arrowIconR');
    handleCollapse('TeslimatAdresiCollapse', 'arrowIconT');
</script>

<style>
    .highlight-animate {
        animation: highlightFade 3s ease;
        box-shadow: 0 0 0 0 rgba(255, 193, 7, 0.7);
    }

    @@keyframes highlightFade {
        0%

    {
        background-color: #fff3cd;
        transform: scale(1.05);
        box-shadow: 0 0 10px 3px rgba(255, 193, 7, 0.6);
    }

    50% {
        background-color: #fff3cd;
        transform: scale(1.08);
        box-shadow: 0 0 15px 5px rgba(255, 193, 7, 0.8);
    }

    100% {
        background-color: transparent;
        transform: scale(1);
        box-shadow: none;
    }

    }
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {

        var lastId = '@TempData["LastReturnId"]';

        if (lastId) {


            // satırı bul
            var row = document.getElementById('return-row-' + lastId);

            if (row) {
                row.scrollIntoView({ behavior: 'smooth', block: 'center' });

                // highlight efekti
                //row.classList.add("bg-warning-subtle");
                row.classList.add("highlight-animate");

                setTimeout(() => {
                    row.classList.remove("highlight-animate");
                }, 3000);
            }
        }
    });




</script>