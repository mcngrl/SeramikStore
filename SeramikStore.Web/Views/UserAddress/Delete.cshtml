@using SeramikStore.Web.Localization
@model SeramikStore.Web.ViewModels.UserAddressViewModel
@inject IStringLocalizer<AccountResource> L
@{
    ViewData["Title"] = "Adres Sil";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-2">
            <partial name="_LeftMenu" />
        </div>
        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-header bg-danger text-white">
                    @L["Adres Sil"]
                </div>

                <div class="card-body">
                    <p>
                        <strong>@Model.Baslik</strong>
                        @L["başlıklı adresi silmek istediğinize emin misiniz?"]
                    </p>

                    <p>
                        @Model.Il / @Model.Ilce <br />
                        @Model.Adres
                    </p>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <button type="submit" class="btn btn-danger">
                            @L["Evet, Sil"]
                        </button>

                        <a asp-action="Index" class="btn btn-secondary">
                            @L["Vazgeç"]
                        </a>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-3">
        </div>
    </div>
</div>

