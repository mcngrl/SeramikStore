@using SeramikStore.Contracts.Category
@using SeramikStore.Entities
@model List<CategoryListItemDto>

@foreach (var cat in Model)
{
    <li class="nav-item">
        <a class="nav-link"
           asp-controller="Home"
           asp-action="Category"
           asp-route-id="@cat.Id">
            @cat.Name
        </a>
    </li>
}