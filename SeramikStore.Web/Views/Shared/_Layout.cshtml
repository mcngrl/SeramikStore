
@using System.Globalization
@using SeramikStore.Web.Localization
@inject IStringLocalizer<AccountResource> L
@inject Microsoft.Extensions.Options.IOptions<SeramikStore.Web.Options.CompanyOptions> Company

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - @Company.Value.Name</title>
    @* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />*@
    @* <link rel="stylesheet" href="~/css/myTheme.css" /> 
    <link href="~/css/journal.min.css" rel="stylesheet" />*@
    <link href="~/css/litera.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
@*     <link rel="stylesheet" href="~/SeramikStore.Web.styles.css" asp-append-version="true" /> *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    @* <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.2/css/all.min.css"> *@
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css" asp-append-version="true" />

</head>
<body>
    <partial name="headerNavigation" />
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["Success"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="successToast" class="toast text-bg-success" role="alert">
                <div class="toast-header text-bg-success">
                    <strong class="me-auto">Success</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">
                    @TempData["Success"]
                </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById('successToast');
                var toast = new bootstrap.Toast(toastEl, { delay: 4000 });
                toast.show();
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="errorToast" class="toast text-bg-danger" role="alert">
                <div class="toast-header text-bg-danger">
                    <strong class="me-auto">Error</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">
                    @TempData["Error"]
                </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById('errorToast');
                var toast = new bootstrap.Toast(toastEl, { delay: 5000 });
                toast.show();
            });
        </script>
    }
    
    @if (TempData["Info"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="infoToast" class="toast text-bg-info" role="alert">
                <div class="toast-header text-bg-info">
                    <strong class="me-auto">Info</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">
                    @TempData["Info"]
                </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById('infoToast');
                var toast = new bootstrap.Toast(toastEl, { delay: 4000 });
                toast.show();
            });
        </script>
    }

    @if (TempData["Required"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="RequiredToast" class="toast text-bg-danger" role="alert">
                <div class="toast-header text-bg-danger">
                    <strong class="me-auto">Lütfen kontrol edin</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">
                    @Html.Raw(TempData["Required"])
                </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById('RequiredToast');
                var toast = new bootstrap.Toast(toastEl, { delay: 5000 });
                toast.show();
            });
        </script>
    }



    <!-- GLOBAL CONFIRM MODAL -->
    <div class="modal fade" id="globalConfirmModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header bg-warning">
                    <h5 class="modal-title text-dark">
                        Onay
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <p id="confirmMessage" class="mb-0">
                        Emin misiniz?
                    </p>
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        Hayır
                    </button>

                    <button type="button"
                            class="btn btn-warning"
                            id="confirmYesButton">
                        Evet
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- FEATURES -->
    <div class="bg-light py-4 border-top">
        <div class="container">
            <div class="row text-center g-4">
                <div class="col-6 col-md-3">
                    <i class="bi bi-box-seam fs-2"></i>
                    <h6 class="mt-2">Aynı Gün Kargo</h6>
                    <small>Hafta içi 12:00’a kadar verilen siparişler aynı gün kargoda.</small>
                </div>
                <div class="col-6 col-md-3">
                    <i class="bi bi-headset fs-2"></i>
                    <h6 class="mt-2">7/24 Canlı Destek</h6>
                    <small>Her an destek sağlıyoruz.</small>
                </div>
                <div class="col-6 col-md-3">
                    <i class="bi bi-stars fs-2"></i>
                    <h6 class="mt-2">Kişiye Özel Tasarım</h6>
                    <small>Hayal edin biz üretelim.</small>
                </div>
                <div class="col-6 col-md-3">
                    <i class="bi bi-shield-check fs-2"></i>
                    <h6 class="mt-2">Güvenli Ödeme</h6>
                    <small>Ödeme bilgileriniz güvende.</small>
                </div>
            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="bg-white pt-5 border-top">
        <div class="container">
            <div class="row g-4">

                <!-- HIZLI ERİŞİM -->
                <div class="col-6 col-md-3">
                    <h6 class="fw-bold">Hızlı Erişim</h6>
                    <ul class="list-unstyled small">
                        <li><a href="/Account/Login">Giriş Yap</a></li>
                        <li><a href="/Account/Profile">Hesabım</a></li>
                        <li><a href="/Order/OrderList">Siparişlerim</a></li>
                        <li><a href="/Order/Track">Sipariş Takip</a></li>
                        <li><a href="/Cart">Sepetim</a></li>
                        <li><a href="/Favorites">Favorilerim</a></li>
                    </ul>
                </div>

                <!-- KATEGORİLER -->
                <div class="col-6 col-md-3">
                    <h6 class="fw-bold">Kategorilerimiz</h6>
                    <ul class="list-unstyled small">
                        @await Component.InvokeAsync("CategoryMenu")
                    </ul>
                </div>

                <!-- POLİTİKALAR -->
                <div class="col-6 col-md-3">
                    <h6 class="fw-bold">Politikalarımız</h6>
                    <ul class="list-unstyled small">
                        <li><a asp-controller="Home" asp-action="Privacy">@L["Gizlilik Politikası"]</a></li>
                        <li><a asp-controller="Home" asp-action="KVKK">@L["KVKK Aydınlatma Metni"]</a></li>
                        <li><a asp-controller="Home" asp-action="UyelikSozlesmesi">@L["Üyelik Sözleşmesi"]</a></li>
                        <li><a asp-controller="Home" asp-action="MesafeliSatis">@L["Mesafeli Satış Sözleşmesi"]</a></li>
@*                         <li><a href="/Home/Cookie">Çerez Politikası</a></li>
                        <li><a href="/Home/Contact">Bize Ulaşın</a></li> *@
                    </ul>
                </div>

                <!-- KURUMSAL -->
                <div class="col-6 col-md-3">
                    <h6 class="fw-bold">Kurumsal</h6>
                    <ul class="list-unstyled small">
                        <li><a href="/Home/About">Hakkımızda</a></li>
@*                         <li><a href="/Home/Search">Hızlı Arama</a></li>
                        <li><a href="/Home/FAQ">Sıkça Sorulan Sorular</a></li> 
                        <li><a href="/Home/Contact">İletişim</a></li>*@
                    </ul>
                </div>

            </div>

            <!-- ALT BAR -->
            <div class="text-center py-3 border-top mt-4 small">
                &copy; @DateTime.Now.Year – @Company.Value.Name 
            </div>
        </div>
    </footer>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const confirmModal = new bootstrap.Modal(document.getElementById('globalConfirmModal'));
            const confirmMessage = document.getElementById('confirmMessage');
            const confirmYesButton = document.getElementById('confirmYesButton');

            window.showConfirm = function (message, onConfirm) {
                confirmMessage.innerText = message;

                confirmYesButton.onclick = function () {
                    confirmModal.hide();
                    onConfirm();
                };

                confirmModal.show();
            };
        });
    </script>

</body>
</html>
