
@using System.Globalization
@using SeramikStore.Web.Localization
@inject IStringLocalizer<AccountResource> L
@inject Microsoft.Extensions.Options.IOptions<SeramikStore.Web.Options.CompanyOptions> Company

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Company.Value.Name  @ViewData["Title"]</title>
    @* <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />*@
    @* <link rel="stylesheet" href="~/css/myTheme.css" /> 
    <link href="~/css/journal.min.css" rel="stylesheet" />*@
    <link href="~/css/litera.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
@*     <link rel="stylesheet" href="~/SeramikStore.Web.styles.css" asp-append-version="true" /> *@
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet">
    @* <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.2/css/all.min.css"> *@
    <link rel="stylesheet" href="~/lib/fontawesome/css/all.min.css" asp-append-version="true" />

</head>
<body>
    <partial name="headerNavigation" />
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @if (TempData["Success"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="successToast" class="toast text-bg-success" role="alert">
                <div class="toast-header text-bg-success">
                    <strong class="me-auto">@L["Başarılı"]</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">
                    @L[TempData["Success"]?.ToString()]
                </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById('successToast');
                var toast = new bootstrap.Toast(toastEl, { delay: 4000 });
                toast.show();
            });
        </script>
    }

    @if (TempData["Error"] != null)
    {
        var errorKey = TempData["Error"]?.ToString();
        var p1 = TempData["P1"];
        var p2 = TempData["P2"];
        var p3 = TempData["P3"];

        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="errorToast" class="toast text-bg-danger" role="alert">
                <div class="toast-header text-bg-danger">
                    <strong class="me-auto">@L["Hata"]</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">
                    @L[errorKey, p1, p2, p3]
                </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById('errorToast');
                var toast = new bootstrap.Toast(toastEl, { delay: 5000 });
                toast.show();
            });
        </script>
    }
    
    @if (TempData["Info"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="infoToast" class="toast text-bg-info" role="alert">
                <div class="toast-header text-bg-info">
                    <strong class="me-auto">@L["Bilgi"]</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">
                    @TempData["Info"]
                </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById('infoToast');
                var toast = new bootstrap.Toast(toastEl, { delay: 4000 });
                toast.show();
            });
        </script>
    }

    @if (TempData["Required"] != null)
    {
        <div class="toast-container position-fixed top-0 end-0 p-3">
            <div id="RequiredToast" class="toast text-bg-danger" role="alert">
                <div class="toast-header text-bg-danger">
                    <strong class="me-auto">@L["Lütfen kontrol edin"]</strong>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="toast"></button>
                </div>
                <div class="toast-body">
                    @Html.Raw(TempData["Required"])
                </div>
            </div>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                var toastEl = document.getElementById('RequiredToast');
                var toast = new bootstrap.Toast(toastEl, { delay: 5000 });
                toast.show();
            });
        </script>
    }



    <!-- GLOBAL CONFIRM MODAL -->
    <div class="modal fade" id="globalConfirmModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">

                <div class="modal-header bg-warning">
                    <h6 class="modal-title text-dark">
                        @L["İşlem Onayı"]
                    </h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body">
                    <p id="confirmMessage" class="mb-0">
                        @L["Emin misiniz?"]
                    </p>
                </div>

                <div class="modal-footer">
                    <button type="button"
                            class="btn btn-secondary"
                            data-bs-dismiss="modal">
                        @L["Hayır"]
                    </button>

                    <button type="button"
                            class="btn btn-warning"
                            id="confirmYesButton">
                        @L["Evet"]  
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- FEATURES -->
    <div class="bg-light py-4 border-top">
        <div class="container">
            <div class="row text-center g-4">

                <div class="col-6 col-md-3">
                    <i class="bi bi-truck fs-2 text-primary"></i>
                    <h6 class="mt-2 fw-semibold">@L["Hızlı Teslimat"]</h6>
                    <small class="text-muted">
                        @L["Siparişleriniz 1–3 iş günü içinde kargoya teslim edilir."]
                    </small>
                </div>

                <div class="col-6 col-md-3">
                    <i class="bi bi-whatsapp fs-2 text-success"></i>
                    <h6 class="mt-2 fw-semibold">@L["Canlı Destek"]</h6>
                    <small class="text-muted">
                        @L["WhatsApp üzerinden hızlı ve kolay destek hizmeti."]
                    </small>
                </div>

                <div class="col-6 col-md-3">
                    <i class="bi bi-arrow-repeat fs-2 text-warning"></i>
                    <h6 class="mt-2 fw-semibold">@L["Kolay İade"]</h6>
                    <small class="text-muted">
                        @L["14 gün içinde ücretsiz iade ve değişim imkanı."]
                    </small>
                </div>

                <div class="col-6 col-md-3">
                    <i class="bi bi-shield-lock fs-2 text-danger"></i>
                    <h6 class="mt-2 fw-semibold">@L["Güvenli Ödeme"]</h6>
                    <small class="text-muted">
                        @L["Sadece EFT ve FAST ile ödeme alınır, kart bilgisi paylaşımı gerekmez."]
                    </small>
                </div>

            </div>
        </div>
    </div>

    <!-- FOOTER -->
    <footer class="bg-white pt-5 border-top">
        <div class="container">
            <div class="row g-4">

                <!-- HIZLI ERİŞİM -->
                <div class="col-6 col-md-3">
                    <h6 class="fw-bold">@L["Hızlı Erişim"]</h6>
                    <ul class="list-unstyled small">
                        <li><a href="/Account/Login">@L["Giriş Yap"]</a></li>
                        <li><a href="/Account/Profile">@L["Hesabım"]</a></li>
                        <li><a href="/Order/OrderList">@L["Siparişlerim"]</a></li>
                        <li><a href="/Cart/Summary">@L["Sepetim"]</a></li>
                    </ul>
                </div>

                <!-- KATEGORİLER -->
                <div class="col-6 col-md-3">
                    <h6 class="fw-bold">@L["Kategorilerimiz"]</h6>
                    <ul class="list-unstyled small">
                        @await Component.InvokeAsync("CategoryMenuFooter")
                    </ul>
                </div>

                <!-- POLİTİKALAR -->
                <div class="col-6 col-md-3">
                    <h6 class="fw-bold">@L["Politikalarımız"]</h6>
                    <ul class="list-unstyled small">
                        <li><a asp-controller="Home" asp-action="Privacy">@L["Gizlilik Politikası"]</a></li>
                        <li><a asp-controller="Home" asp-action="KVKK">@L["KVKK Aydınlatma Metni"]</a></li>
                        <li><a asp-controller="Home" asp-action="UyelikSozlesmesi">@L["Üyelik Sözleşmesi"]</a></li>
                        <li><a asp-controller="Home" asp-action="MesafeliSatis">@L["Mesafeli Satış Sözleşmesi"]</a></li>
                        <li><a asp-controller="Home" asp-action="CookiePolicy">@L["Çerez Politikası"]</a></li>
                        @*<li><a href="/Home/Contact">Bize Ulaşın</a></li> *@
                    </ul>
                </div>

                <!-- KURUMSAL -->
                <div class="col-6 col-md-3">
                    <h6 class="fw-bold">@L["Kurumsal"]</h6>

                    <ul class="list-unstyled small">
                        <li>
                            <a href="/Home/About">
                                @L["Hakkımızda"]
                            </a>
                        <li>
                            <a href="/Home/SSS">
                                @L["Sıkça Sorulan Sorular"]
                            </a>
                        </li>
                    </ul>
                    <div class="d-flex gap-3 mt-1 align-items-start">

                        <!-- Instagram -->
                        <div class="text-center">
                            <a href="https://instagram.com/@(Company.Value.SocialMedia.Instagram)"
                               target="_blank"
                               class="social-icon instagram"
                               aria-label="Instagram">
                                <i class="fa-brands fa-instagram fs-4"></i>
                            </a>

                            <div class="mt-2 small text-dark">
                                @(Company.Value.SocialMedia.Instagram)
                            </div>
                        </div>

                        <!-- WhatsApp -->
                        <div class="text-center">
                            <a href="https://wa.me/@(Company.Value.SocialMedia.WhatsApp)"
                               target="_blank"
                               class="social-icon whatsapp">
                                <i class="fa-brands fa-whatsapp fs-4"></i>
                            </a>

                            <div class="mt-2 small text-dark">
                                @(Company.Value.SocialMedia.WhatsApp)
                            </div>
                        </div>

                    </div>

                </div>


            </div>

            <!-- ALT BAR -->
            <div class="text-center py-3 border-top mt-4 small">
                &copy; @DateTime.Now.Year – @Company.Value.Name 
            </div>
        </div>
    </footer>
    <div id="cookieBanner" class="cookie-banner d-none">
        <div class="container d-flex flex-column flex-md-row align-items-center justify-content-between">

            <div class="text-white small mb-2 mb-md-0">
                @L["Bu web sitesi, sepet işlemleri ve oturum yönetimi için zorunlu çerezler kullanır.Detaylı bilgi için"]
                <a href="/Home/CookiePolicy" class="text-warning text-decoration-underline">
                    @L["Çerez Politikası"]
                </a> @L["sayfamızı inceleyebilirsiniz."]
            </div>

            <div>
                <button class="btn btn-success btn-sm" onclick="acceptCookies()">
                    @L["Anladım"]
                </button>
            </div>

        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const confirmModal = new bootstrap.Modal(document.getElementById('globalConfirmModal'));
            const confirmMessage = document.getElementById('confirmMessage');
            const confirmYesButton = document.getElementById('confirmYesButton');

            window.showConfirm = function (message, onConfirm) {
                confirmMessage.innerText = message;

                confirmYesButton.onclick = function () {
                    confirmModal.hide();
                    onConfirm();
                };

                confirmModal.show();
            };
        });
    </script>
    <script>
        function setCookie(name, value, days) {
            var expires = "";
            if (days) {
                var date = new Date();
                date.setTime(date.getTime() + (days * 24 * 60 * 60 * 1000));
                expires = "; expires=" + date.toUTCString();
            }
            document.cookie = name + "=" + value + "; path=/" + expires;
        }

        function getCookie(name) {
            var nameEQ = name + "=";
            var ca = document.cookie.split(';');
            for (var i = 0; i < ca.length; i++) {
                var c = ca[i].trim();
                if (c.indexOf(nameEQ) == 0) return c.substring(nameEQ.length);
            }
            return null;
        }

        function acceptCookies() {
            setCookie("cookieConsent", "shown", 365);
            document.getElementById("cookieBanner").classList.add("d-none");
        }

        window.onload = function () {
            var consent = getCookie("cookieConsent");

            if (!consent) {
                document.getElementById("cookieBanner").classList.remove("d-none");
            }
        };
    </script>
    <style>

        .footer-links li a {
            color: rgba(255,255,255,.75);
            text-decoration: none;
            transition: .2s;
        }

            .footer-links li a:hover {
                color: white;
                padding-left: 5px;
            }

        .social-icon {
            width: 42px;
            height: 42px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-decoration: none;
            font-size: 20px;
            transition: .25s;
        }

            .social-icon:hover {
                transform: translateY(-4px);
            }

        .instagram {
            background: linear-gradient(45deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);
        }

        .whatsapp {
            background: #25D366;
        }

        .cookie-banner {
            position: fixed;
            bottom: 0;
            left: 0;
            width: 100%;
            background: #212529;
            padding: 15px;
            z-index: 9999;
        }
    </style>
</body>
</html>
