@using SeramikStore.Web.Localization
@inject IStringLocalizer<CommonResource> L
@model SeramikStore.Web.ViewModels.ProductDetail

<div class="container mt-4">
    <div class="row g-4">

        <!-- SOL: IMAGE GALERİ -->
        <div class="col-md-6">
            <div class="border rounded p-3 bg-white">
                <!-- ANA RESİM -->
                <div class="position-relative text-center mb-3">
                    <img id="mainImage"
                         src="@(Model.ImagePaths?.FirstOrDefault() ?? "/images/no-image.png")"
                         class="img-fluid"
                         style="max-height:520px; object-fit:contain; cursor:zoom-in;"
                         onclick="openLightbox(currentIndex)"
                         title="Büyütmek için tıklayın" />

                    @* Büyüt ikonu *@
                    <span class="position-absolute bottom-0 end-0 m-2 bg-white rounded px-2 py-1 small text-muted"
                          style="cursor:pointer; opacity:0.85;"
                          onclick="openLightbox(currentIndex)">
                        <i class="bi bi-arrows-fullscreen"></i>@L["Büyüt"]
                    </span>

                    <button type="button"
                            class="btn btn-light position-absolute top-50 start-0 translate-middle-y"
                            onclick="prevImage()">
                        ❮
                    </button>

                    <button type="button"
                            class="btn btn-light position-absolute top-50 end-0 translate-middle-y"
                            onclick="nextImage()">
                        ❯
                    </button>
                </div>

                <!-- THUMBNAILS -->
                <div class="d-flex justify-content-center gap-2 flex-wrap">
                    @for (int i = 0; i < Model.ThumbPaths.Count; i++)
                    {
                        <img src="@Model.ThumbPaths[i]"
                             class="img-thumbnail"
                             style="width:90px;height:90px;object-fit:cover;cursor:pointer"
                             onclick="setImage(@i)" />
                    }
                </div>
            </div>
        </div>

        <!-- SAĞ: ÜRÜN BİLGİLERİ -->
        <div class="col-md-6">
            <div class="bg-white border rounded p-4 h-100">

                <small class="text-muted">@L["Ürün Kodu"]:<strong>@Model.ProductCode</strong></small>
                <h6 class="mt-2 fw-bold">@L[Model.ProductName]</h6>

                <!-- FİYAT -->
                <div class="my-3">
                    <span class="fs-6 fw-bold text-danger">
                        @Model.UnitPrice.ToString("N2", new System.Globalization.CultureInfo("tr-TR"))
                        @Model.CurrencyCode
                    </span>
                </div>

                <!-- STOK DURUMU -->
                <div class="mb-3">
                    @if (Model.StockAmount <= 0)
                    {
                        <span class="badge bg-danger fs-6 px-3 py-2">
                            <i class="bi bi-x-circle me-1"></i>@L["Stok Tükendi"]
                        </span>
                    }
                    else if (Model.StockAmount <= 5)
                    {
                        <span class="badge bg-warning text-dark fs-6 px-3 py-2">
                            <i class="bi bi-exclamation-triangle me-1"></i>
                            @L["Son {0} adet!", Model.StockAmount]
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-success fs-6 px-3 py-2">
                            <i class="bi bi-check-circle me-1"></i>
                            @L["Stokta {0} adet mevcut", Model.StockAmount]
                        </span>
                    }
                </div>

                <!-- ADET + SEPET -->
                @if (Model.StockAmount > 0)
                {
                    <form asp-action="Cart" method="post" class="mt-3" id="addToCartForm">
                        <input type="hidden" asp-for="Id" />
                        <div class="mb-3">
                            <label class="form-label">@L["Adet"]</label>
                            <div class="d-flex align-items-center gap-2">
                                <button type="button" class="btn btn-outline-secondary" onclick="changeQty(-1)">−</button>
                                <input asp-for="Quantity"
                                       id="quantityInput"
                                       type="number"
                                       min="1"
                                       max="@Model.StockAmount"
                                       value="1"
                                       class="form-control text-center"
                                       style="width:80px"
                                       onchange="validateQty()" />
                                <button type="button" class="btn btn-outline-secondary" onclick="changeQty(1)">+</button>
                                <span class="text-muted small">@L["Max"] @Model.StockAmount @L["adetmiktar"]</span>
                            </div>
                            <span asp-validation-for="Quantity" class="text-danger"></span>
                            <div id="stockWarning" class="text-danger small mt-1 d-none">
                                <i class="bi bi-exclamation-circle"></i>
                                @L["Maksimum"] <strong>@Model.StockAmount</strong> @L["adet ekleyebilirsiniz."]
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary" id="addToCartBtn">
                            <i class="bi bi-cart-plus"></i> @L["Sepete Ekle"]
                        </button>
                    </form>
                }
                else
                {
                    <button class="btn btn-secondary mt-3" disabled>
                        <i class="bi bi-cart-x"></i> @L["Sepete Ekle"]
                    </button>
                }

                <hr />

                <h5>@L["Ürün Açıklaması"]</h5>
                <div class="product-description">
                    @Html.Raw(Model.ProductDesc)
                </div>
            </div>
        </div>
    </div>
</div>

@* LIGHTBOX MODAL *@
<div class="modal fade" id="lightboxModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered m-0 w-100" style="max-width:100%;">
        <div class="modal-content bg-dark border-0">
            <div class="modal-header border-0 pb-0">
                <span class="text-white small" id="lightboxCounter"></span>
                <div class="ms-auto d-flex gap-2">
                    @* Orijinal boyutta aç *@
                    <a id="lightboxOpenLink"
                       href="#"
                       target="_blank"
                       class="btn btn-sm btn-outline-light">
                        <i class="bi bi-box-arrow-up-right"></i>@L["Orijinal Boyut"]
                    </a>
                    <button type="button" class="btn btn-sm btn-outline-light" data-bs-dismiss="modal">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>
            <div class="modal-body text-center p-2 position-relative">
                <img id="lightboxImage"
                     src=""
                     class="img-fluid"
                     style="max-height:95vh; object-fit:contain;" />

                @* Sol / Sağ oklar *@
                <button class="btn btn-dark opacity-75 position-absolute top-50 start-0 translate-middle-y ms-2"
                        onclick="lightboxPrev()">
                    ❮
                </button>
                <button class="btn btn-dark opacity-75 position-absolute top-50 end-0 translate-middle-y me-2"
                        onclick="lightboxNext()">
                    ❯
                </button>
            </div>
        </div>
    </div>
</div>

<!-- JS -->
<script>
    const images   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ImagePaths ?? new List<string>()));
    const maxStock = @Model.StockAmount;
    let currentIndex = 0;

    // --- Galeri ---
    function setImage(index) {
        currentIndex = index;
        document.getElementById("mainImage").src = images[index];
    }

    function prevImage() {
        if (images.length === 0) return;
        currentIndex = (currentIndex - 1 + images.length) % images.length;
        setImage(currentIndex);
    }

    function nextImage() {
        if (images.length === 0) return;
        currentIndex = (currentIndex + 1) % images.length;
        setImage(currentIndex);
    }

    // --- Lightbox ---
    let lightboxIndex = 0;

    function openLightbox(index) {
        lightboxIndex = index;
        updateLightbox();
        new bootstrap.Modal(document.getElementById("lightboxModal")).show();
    }

    function updateLightbox() {
        const img  = document.getElementById("lightboxImage");
        const link = document.getElementById("lightboxOpenLink");
        const counter = document.getElementById("lightboxCounter");
        img.src    = images[lightboxIndex];
        link.href  = images[lightboxIndex];
        counter.textContent = (lightboxIndex + 1) + " / " + images.length;
    }

    function lightboxPrev() {
        lightboxIndex = (lightboxIndex - 1 + images.length) % images.length;
        updateLightbox();
    }

    function lightboxNext() {
        lightboxIndex = (lightboxIndex + 1) % images.length;
        updateLightbox();
    }

    // Klavye ok tuşları
    document.addEventListener("keydown", function (e) {
        const modal = document.getElementById("lightboxModal");
        if (!modal.classList.contains("show")) return;
        if (e.key === "ArrowLeft")  lightboxPrev();
        if (e.key === "ArrowRight") lightboxNext();
        if (e.key === "Escape")     bootstrap.Modal.getInstance(modal)?.hide();
    });

    // --- Stok ---
    function changeQty(delta) {
        const input = document.getElementById("quantityInput");
        let val = parseInt(input.value) + delta;
        val = Math.max(1, Math.min(val, maxStock));
        input.value = val;
        validateQty();
    }

    function validateQty() {
        const input   = document.getElementById("quantityInput");
        const warning = document.getElementById("stockWarning");
        const btn     = document.getElementById("addToCartBtn");
        let val = parseInt(input.value);

        if (isNaN(val) || val < 1) { input.value = 1; val = 1; }

        if (val > maxStock) {
            input.value = maxStock;
            warning.classList.remove("d-none");
            btn.disabled = true;
        } else {
            warning.classList.add("d-none");
            btn.disabled = false;
        }
    }

    document.getElementById("addToCartForm")?.addEventListener("submit", function (e) {
        const qty = parseInt(document.getElementById("quantityInput").value);
        if (qty > maxStock || qty < 1) { e.preventDefault(); validateQty(); }
    });
</script>