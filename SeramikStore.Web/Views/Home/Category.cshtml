@using SeramikStore.Web.Localization
@inject IStringLocalizer<AccountResource> L
@model SeramikStore.Services.DTOs.ProductListByCategoryForHomeDto
@using System.Globalization

@if (Model.CategoryId > 0)
{
    @await Component.InvokeAsync("Carousel")
}


<div class="container-fluid px-1 px-md-1 py-1">
    <div class="row g-4">
        @await Component.InvokeAsync("CategoryMenuMainPage", new { selectedCategoryId = Model.CategoryId }) 

        <div class="col-12 col-md-10">
            <div class="row row-cols-2 row-cols-sm-2 row-cols-md-3 row-cols-xl-4 g-3">
                @foreach (var item in Model.ProductList)
                {
                    var inStock = item.StockAmount > 0;

                    <div class="col">
                        <div class="product-card @(!inStock ? "out-of-stock" : "")">
                            <a asp-action="Details"
                               asp-controller="Home"
                               asp-route-id="@item.Id"
                               class="text-decoration-none d-block">

                                <div class="product-img-wrap">
                                    <img src="@(string.IsNullOrEmpty(item.MainImagePath)
                                                                                           ? "/images/no-image.png"
                                                                                                                                    : item.MainImagePath)"
                                     alt="@item.ProductName"
                                     class="product-img" />


                                    @if (!inStock)
                                    {
                                        <span class="stock-overlay"></span>
                                    }
                                </div>

                                <div class="product-body">
            
                                    <h6 class="card-title text-dark fw-semibold">
                                        @item.ProductName
                                    </h6>
                                     <div class="fw-bold text-primary">
                                        @item.UnitPrice.ToString("N2", new System.Globalization.CultureInfo("tr-TR"))
                                        <small>@item.CurrencyCode</small>
                    
                                    </div>

                                    <div class="mt-1">
                                        @if (item.StockAmount <= 0)
                                        {
                                            <span class="stock-badge stock-out">
                                                @L["Tükendi"]
                                            </span>
                                        }
                                        else if (item.StockAmount <= 5)
                                        {
                                            <span class="stock-badge stock-low">
                                                @L["Son {0} adet!", item.StockAmount]
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="stock-badge stock-in">
                                                @L["Stokta: {0} adet", item.StockAmount]
                                            </span>
                                        }
                                    </div>
                                </div>
                            </a>

                            <div class="cart-action">
                                @if (inStock)
                                {
                                    <form asp-action="Cart"
                                          asp-controller="Home"
                                          method="post"
                                          class="cart-form">
                                        <input type="hidden" name="Id" value="@item.Id" />
                                        <input type="hidden" name="Quantity" value="1" />
                                        <button type="submit" class="cart-btn-full">
                                            <i class="bi bi-cart-plus"></i>
                                            <span>@L["Sepete Ekle"]</span>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <button class="cart-btn-full disabled" disabled>
                                        <i class="bi bi-x-circle"></i>
                                        <span>@L["Sepete Ekle"]</span>
                                    </button>
                                }

                                <a asp-action="Details"
                                   asp-controller="Home"
                                   asp-route-id="@item.Id"
                                   class="cart-btn-full cart-btn-outline mt-2">
                                    <i class="bi bi-eye"></i>
                                    <span>@L["İncele"]</span>
                                </a>
                            </div>

                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

