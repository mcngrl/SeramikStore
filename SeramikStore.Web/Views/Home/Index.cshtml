<div class="row g-4 mt-2">

    <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm h-100 text-center p-4 feature-card">

        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm h-100 text-center p-4 feature-card">
            <div class="mb-3 text-danger">
                <i class="bi bi-fire fs-1"></i>
            </div>

            <h4 class="fw-bold">1240°C Yüksek Fırınlama</h4>

            <p class="text-muted mb-0">
                Yüksek sıcaklıkta pişirilerek ekstra dayanıklılık
                ve uzun ömürlü kullanım elde edilir.
            </p>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm h-100 text-center p-4 feature-card">
            <div class="mb-3 text-success">
                <i class="bi bi-microwave fs-1"></i>
            </div>

            <h4 class="fw-bold">Mikrodalga Uyumlu</h4>

            <p class="text-muted mb-0">
                Günlük kullanım için tasarlanmıştır.
                Güvenle mikrodalgada kullanılabilir.
            </p>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm h-100 text-center p-4 feature-card">
            <div class="mb-3 text-info">
                <i class="bi bi-droplet-half fs-1"></i>
            </div>

            <h4 class="fw-bold">Bulaşık Makinesi Dostu</h4>

            <p class="text-muted mb-0">
                Özel yüzey yapısı sayesinde rengini ve dokusunu
                uzun yıllar korur.
            </p>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm h-100 text-center p-4 feature-card">
            <div class="mb-3 text-warning">
                <i class="bi bi-shield-check fs-1"></i>
            </div>

            <h4 class="fw-bold">Çizilmeye Dayanıklı Yüzey</h4>

            <p class="text-muted mb-0">
                Renk yüzeyde değil çamurun içindedir.
                Kullanıma bağlı deformasyonları minimuma indirir.
            </p>
        </div>
    </div>

    <div class="col-lg-4 col-md-6">
        <div class="card border-0 shadow-sm h-100 text-center p-4 feature-card">
            <div class="mb-3 text-secondary">
                <i class="bi bi-globe-europe-africa fs-1"></i>
            </div>

            <h4 class="fw-bold">Doğal ve Zamansız Tasarım</h4>

            <p class="text-muted mb-0">
                Modern sofralara uyum sağlayan,
                sade ve doğal dokulu özel stoneware tasarımlar.
            </p>
        </div>
    </div>

</div>

<style>
    .feature-card {
        transition: all .25s ease;
        border-radius: 18px;
    }

        .feature-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(0,0,0,.12) !important;
        }
</style>
<!-- PRODUCTS -->
<div class="container">
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
                <a asp-action="Details"
                   asp-controller="Home"
                   asp-route-id="@item.Id"
                   class="text-decoration-none">

                    <div class="card h-100 shadow-sm border-0 product-card">
                        <img src="@(string.IsNullOrEmpty(item.MainImagePath)
                                                         ? "/images/no-image.png"
                                                         : item.MainImagePath)"
                         class="card-img-top"
                         style="height:180px;object-fit:cover;" />

                        <div class="card-body">
                            <h6 class="card-title text-dark fw-semibold">
                                @item.ProductName
                            </h6>

                            <div class="fw-bold text-primary">
                                @item.UnitPrice.ToString("N2", new System.Globalization.CultureInfo("tr-TR"))
                                <small>@item.CurrencyCode</small>
                            </div>
                        </div>
                    </div>

                </a>
            </div>
                }
    </div>
</div>