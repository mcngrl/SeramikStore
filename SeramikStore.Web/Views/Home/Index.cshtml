@using SeramikStore.Web.Localization
@inject IStringLocalizer<AccountResource> L
<div id="myCarousel" class="carousel slide mb-5" data-bs-ride="false">


    <div class="carousel-inner rounded shadow-sm">

        @{
            var carouselItems = new[]
            {
                new { Image = "sunumluk",  Title = "El Yapımı Stoneware Ürünler",     Desc = "Şimdi keşfedin, özel tasarımlar sizi bekliyor" },
                new { Image = "sunumluk2", Title = "Her Parça Bir Hikaye",            Desc = "El işçiliği ile üretilen benzersiz stoneware koleksiyonu" },
                new { Image = "zeytin",    Title = "Her Parça Eşsizdir",              Desc = "El yapımı olduğu için her ürün kendine özgü bir karakter taşır" },
                new { Image = "denizati",  Title = "Sofranıza Değer Katın",           Desc = "Özgün tasarımlar ile fark yaratan sunumlar" },
                new { Image = "kabuk2",     Title = "Doğadan İlham Alan Tasarımlar",   Desc = "Doğal dokular ve formlar ile tasarlanmış özel stoneware ürünler" },
                new { Image = "kopekli",   Title = "El İşçiliğinin Zarafeti",         Desc = "Her biri ustalıkla elde şekillendirilen benzersiz parçalar" },
                new { Image = "mavikuyruk", Title = "Minimal ve Şık",                 Desc = "Sade tasarım anlayışıyla modern sofralara uyum sağlar" },
                new { Image = "salyangoz", Title = "Dayanıklılık ve Estetik",         Desc = "Yüksek ısıda üretilen uzun ömürlü stoneware ürünler" },
                new { Image = "yengec",    Title = "Günlük Kullanıma Uygun",          Desc = "Hem şık hem pratik ürünlerle her gün keyifli kullanım" },
             
                };
        }
        @for (int i = 0; i < carouselItems.Length; i++)
        {
            var item = carouselItems[i];
            <div class="carousel-item @(i == 0 ? "active" : "")">
                <img src="/images/banner/@(item.Image).webp"
                     class="d-block w-100"
                     style="height:500px;object-fit:cover;" />
                <div class="carousel-caption text-start"
                     style="top:25%; left:10%; right:auto; bottom:auto; max-width:600px;">
                    <h1 class="fw-bold">@L[item.Title]</h1>
                    <p>@L[item.Desc]</p>
                </div>
            </div>
        }
    </div>
    <div class="carousel-indicators">
        @for (int i = 0; i < carouselItems.Length; i++)
        {
            <button type="button"
                    data-bs-target="#myCarousel"
                    data-bs-slide-to="@i"
                    class="@(i == 0 ? "active" : "")"
                    aria-label="Slide @(i + 1)"
                    @(i == 0 ? "aria-current=true" : "")>
            </button>
        }
    </div>

    <!-- SOL OK -->
    <button class="carousel-control-prev" type="button" data-bs-target="#myCarousel" data-bs-slide="prev">
        <span style="background:rgba(0,0,0,0.4); border-radius:50%; width:44px; height:44px; display:flex; align-items:center; justify-content:center;">
            <svg width="20" height="20" fill="white" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M11.354 1.646a.5.5 0 0 1 0 .708L5.707 8l5.647 5.646a.5.5 0 0 1-.708.708l-6-6a.5.5 0 0 1 0-.708l6-6a.5.5 0 0 1 .708 0z" />
            </svg>
        </span>
    </button>

    <!-- SAĞ OK -->
    <button class="carousel-control-next" type="button" data-bs-target="#myCarousel" data-bs-slide="next">
        <span style="background:rgba(0,0,0,0.4); border-radius:50%; width:44px; height:44px; display:flex; align-items:center; justify-content:center;">
            <svg  width="20" height="20" fill="white" viewBox="0 0 16 16">
                <path fill-rule="evenodd" d="M4.646 1.646a.5.5 0 0 1 .708 0l6 6a.5.5 0 0 1 0 .708l-6 6a.5.5 0 0 1-.708-.708L10.293 8 4.646 2.354a.5.5 0 0 1 0-.708z" />
            </svg>
        </span>
    </button>
</div>
<section class="py-5 bg-light">
    <div class="container">

        <div class="text-center mb-5">
            <h2 class="fw-bold">@L["Her Detayında El Emeği Saklı"]</h2>
            <p class="text-muted">
                @L["Her parça; ustalık, sabır ve yüksek sıcaklıkta şekillenen gerçek bir el işçiliği ürünüdür."]
            </p>
        </div>

        <div class="row g-4 mb-2">

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                     <div class="mb-3 text-primary">
                        <i class="bi bi-hand-index-thumb fs-1"></i>
                    </div>

                    <h4 class="fw-bold">@L["El Yapımı"]</h4>

                    <p class="text-muted mb-0">
                        @L["Her parça ellerimizde tek tek şekillendirilir, bu yüzden her ürün kendine özgü bir karakter taşır."]
                    </p>

                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                    <div class="mb-3 text-danger">
                        <i class="bi bi-fire fs-1"></i>
                    </div>

                    <h4 class="fw-bold">@L["Yüksek Fırınlama"]</h4>

                    <p class="text-muted">
                        @L["Yüksek sıcaklıkta pişirilerek ekstra dayanıklılık ve uzun ömürlü kullanım elde edilir."]
                    </p>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 text-center p-4">
                    <div class="mb-3">
                        <i class="bi bi-shield-check fs-1"></i>
                    </div>

                    <h4 class="fw-bold">@L["Mikrodalga Uyumlu"]</h4>

                    <p class="text-muted">
                        @L["Günlük kullanım için tasarlanmıştır. Güvenle mikrodalgada kullanılabilir."]
                    </p>
                </div>
            </div>

        </div>


    </div>
</section>



<style>
    .feature-card {
        transition: all .25s ease;
        border-radius: 18px;
    }

        .feature-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(0,0,0,.12) !important;
        }
</style>
<!-- PRODUCTS -->
<div class="container">
    <div class="row g-4">
        @foreach (var item in Model)
        {
            <div class="col-xl-2 col-lg-3 col-md-4 col-sm-6">
                <a asp-action="Details"
                   asp-controller="Home"
                   asp-route-id="@item.Id"
                   class="text-decoration-none">
                    <div class="card h-100 shadow-sm border-0 product-card position-relative">

                        @* Tükenmiştir rozeti *@
                        @if (item.StockAmount <= 0)
                        {
                            <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center"
                                 style="background:rgba(0,0,0,0.45); border-radius: inherit; z-index:1;">
                            </div>
                        }

                        <img src="@(string.IsNullOrEmpty(item.MainImageThumbPath)
                                                                  ? "/images/no-image.png"
                                                                                               : item.MainImageThumbPath)"
                         class="card-img-top @(item.StockAmount <= 0 ? "opacity-50" : "")"
                         style="height:180px; object-fit:cover;" />

                        <div class="card-body">
                            <h6 class="card-title text-dark fw-semibold">
                                @item.ProductName
                            </h6>
                            <div class="fw-bold text-primary">
                                @item.UnitPrice.ToString("N2", new System.Globalization.CultureInfo("tr-TR"))
                                <small>@item.CurrencyCode</small>
                            </div>

                            @* Stok durumu *@
                            <div class="mt-2">
                            @if (item.StockAmount <= 0)
                                {
                                    <span class="badge bg-danger">
                                        @L["Tükendi"]
                                    </span>
                                }
                                else if (item.StockAmount <= 5)
                                {
                                    <span class="badge bg-warning text-dark">
                                        @L["Son {0} adet!", item.StockAmount]
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        @L["Stokta: {0} adet", item.StockAmount]
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<div class="row g-4 mb-2">

    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div class="mb-3 text-success">
                <i class="bi bi-droplet fs-1"></i>
            </div>
            <h4 class="fw-bold">@L["Bulaşık Makinesine Uygun"]</h4>
            <p class="text-muted mb-0">
                @L["Stoneware yapısı sayesinde bulaşık makinesinde güvenle yıkanabilir, formunu ve rengini korur."]
            </p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div class="mb-3 text-warning">
                <i class="bi bi-check-circle fs-1"></i>
            </div>
            <h4 class="fw-bold">@L["Gıda ile Temasa Uygun"]</h4>
            <p class="text-muted">
                @L["Sağlığa zararsızdır, tüm ürünlerimiz gıda ile temas için güvenle kullanılabilir."]
            </p>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm h-100 text-center p-4">
            <div class="mb-3 text-primary">
                <i class="bi bi-box-seam fs-1"></i>
            </div>
            <h4 class="fw-bold">@L["Özenli Paketleme"]</h4>
            <p class="text-muted">
                @L["Siparişleriniz özel korumalı ambalajlarla hazırlanır ve güvenle adresinize ulaştırılır."]
            </p>
        </div>
    </div>

</div>

