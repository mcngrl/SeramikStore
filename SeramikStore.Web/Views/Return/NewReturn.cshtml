@using SeramikStore.Contracts.Return
@model ReturnCreateViewDto

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">

            <h5 class="mb-4">
                <i class="fa-solid fa-rotate-left me-2"></i>
                Yeni İade Talebi
            </h5>
            <span asp-validation-for="Items" class="text-danger"></span>
            <form asp-action="CreateReturn" method="post">
                <input type="hidden" asp-for="OrderId" />

                <div class="row g-3">
                    @for (int i = 0; i < Model.Items.Count; i++)
                    {
                        var item = Model.Items[i];

                        <div class="col-12">
                            <div class="border rounded p-3 d-flex align-items-center justify-content-between">
                                
                                <!-- SOL: Ürün -->
                                <div class="d-flex align-items-center gap-3">
                                    <img src="@(string.IsNullOrEmpty(item.ImagePath) ? "/images/no-image.png" : item.ImagePath)"
                                         style="width:60px;height:60px;object-fit:cover;border-radius:8px;" />

                                    <div>
                                        <div style="font-weight:500">@item.ProductName</div>
                                        <small class="text-muted">@item.ProductCode</small>
                                        <div class="text-success small mt-1">
                                            Kalan: @item.AvaliableQuatityForReturn adet
                                        </div>
                                    </div>
                                </div>

                                <!-- SAĞ: Aksiyon -->
                                <div class="text-center">

                                    <div class="d-flex align-items-center gap-2 justify-content-center mb-1">
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary"
                                                onclick="decrease(@i)">
                                            -
                                        </button>

                                        <input type="number"
                                               id="qty-@i"
                                               asp-for="Items[@i].ReturnQuantity"
                                               class="form-control form-control-sm text-center"
                                               style="width:60px"
                                               min="0"
                                               max="@item.AvaliableQuatityForReturn" 
                                               />

                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary"
                                                onclick="increase(@i, @item.AvaliableQuatityForReturn)">
                                            +
                                        </button>
                                    </div>

                                    <button type="button"
                                            class="btn btn-link btn-sm p-0"
                                            onclick="setMax(@i, @item.AvaliableQuatityForReturn)">
                                        Tümünü İade Et
                                    </button>

                                    <!-- hidden -->
                                    <input type="hidden" asp-for="Items[@i].OrderDetailId" />
                                    <input type="hidden" asp-for="Items[@i].ProductId" />

                                </div>

                            </div>
                        </div>
                    }
                </div>

                <div class="mt-4">
                    <label class="form-label">İade Sebebi</label>
                    
                    <select asp-for="Reason"  id="reasonSelect" class="form-select mb-2" onchange="toggleCustomReason()">
                        <option value="">Seçiniz</option>
                        <option>Ürün hasarlı geldi</option>
                        <option>Yanlış ürün gönderildi</option>
                        <option>Beklentimi karşılamadı</option>
                        <option>Açıklamayla uyuşmuyor</option>
                        <option>Geç teslim edildi</option>
                        <option>Siparişi yanlış verdim</option>
                        <option>Sebep belirtmek istemiyorum</option>
                        <option value="other">Diğer</option>
                    </select>
                    <span asp-validation-for="Reason" class="text-danger"></span>
                   
                    <textarea id="customReason"
                              asp-for="Reason"
                              class="form-control"
                              rows="3"
                              placeholder="Lütfen açıklayınız..."
                              style="display:none;">
                   </textarea>

                </div>

                <!-- Submit -->
                <div class="text-end mt-3">
                    <button type="submit" class="btn btn-danger">
                        <i class="fa-solid fa-check me-1"></i>
                        İade Talebi Oluştur
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>


<script>
   function increase(i, max) {
        let el = document.getElementById("qty-" + i);
        let val = parseInt(el.value || 0);

         el.value = val + 1;
        if (val < max) el.value = val + 1; 
    }

    function decrease(i) {
        let el = document.getElementById("qty-" + i);
        let val = parseInt(el.value || 0);
        if (val > 0) el.value = val - 1;
    }

    function setMax(i, max) {
        document.getElementById("qty-" + i).value = max;
    }


</script>

<script>
    function toggleCustomReason() {
    var select = document.getElementById("reasonSelect");
    var textarea = document.getElementById("customReason");

    if (select.value === "other") {
        textarea.style.display = "block";
        textarea.value = "";
    } else {
        textarea.style.display = "none";
        textarea.value = select.value;
    }


    }
</script>