@model IEnumerable<SeramikStore.Services.DTOs.ProductListForAdminDto>

@{
    ViewData["Title"] = "Ürün Listesi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">

            <h6 class="mb-3 d-flex align-items-center gap-2">
                <i class="bi bi-box-seam me-1"></i>
                Ürün Listesi
                <span class="badge bg-secondary fw-normal">@Model.Count() ürün</span>
            </h6>

            <div class="d-flex flex-wrap gap-2 mb-3">
                <a asp-action="Create" class="btn btn-sm btn-primary">
                    <i class="bi bi-plus-lg me-1"></i> Yeni Ürün
                </a>
                <button id="btnSaveOrder" class="btn btn-sm btn-success">
                    <i class="bi bi-save me-1"></i> Sıralamayı Kaydet
                </button>

                <a asp-controller="Admin" asp-action="Index" class="btn btn-sm btn-outline-secondary ms-auto">
                    <i class="bi bi-speedometer2 me-1"></i> Yönetim Paneli
                </a>
            </div>

            @* MASAÜSTÜ TABLO *@
            <div class="d-none d-lg-block table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th style="width:30px;"></th>
                            <th>@Html.DisplayNameFor(model => model.Id)</th>
                            <th>@Html.DisplayNameFor(model => model.ProductCode)</th>
                            <th>@Html.DisplayNameFor(model => model.ProductName)</th>
                            <th class="text-end">@Html.DisplayNameFor(model => model.UnitPrice)</th>
                            <th class="text-center">@Html.DisplayNameFor(model => model.AvailableForSale)</th>
                            <th class="text-center">@Html.DisplayNameFor(model => model.StockAmount)</th>
                            <th>@Html.DisplayNameFor(model => model.MainImageThumbPath)</th>
                            <th class="text-center">@Html.DisplayNameFor(model => model.ImageCount)</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="sortable-products">
                        @foreach (var item in Model)
                        {
                            <tr data-id="@item.Id">
                                <td class="drag-handle text-muted" style="cursor:grab;">☰</td>
                                <td class="small text-muted">@Html.DisplayFor(modelItem => item.Id)</td>
                                <td class="small">@Html.DisplayFor(modelItem => item.ProductCode)</td>
                                <td>@Html.DisplayFor(modelItem => item.ProductName)</td>
                                <td class="text-end small" style="font-family:monospace;">
                                    @item.UnitPrice.ToString("N2", new System.Globalization.CultureInfo("tr-TR"))
                                    @Html.DisplayFor(modelItem => item.CurrencyCode)
                                </td>
                                <td class="text-center">
                                    @if (item.AvailableForSale)
                                    {
                                        <span class="badge bg-success">Evet</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Hayır</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.StockAmount <= 0)
                                    {
                                        <span class="badge bg-danger">@item.StockAmount</span>
                                    }
                                    else if (item.StockAmount <= 5)
                                    {
                                        <span class="badge bg-warning text-dark">@item.StockAmount</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@item.StockAmount</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.MainImageThumbPath))
                                    {
                                        <img src="@item.MainImageThumbPath" alt="Ürün Resmi"
                                             style="width:50px;height:50px;object-fit:cover;border-radius:4px;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Resim yok</span>
                                    }
                                </td>
                                <td class="text-center small">@Html.DisplayFor(modelItem => item.ImageCount)</td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (item.ImageCount > 0)
                                        {
                                            <button class="btn btn-sm btn-danger" disabled>
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-danger">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                        <a asp-controller="ProductImage" asp-action="Index"
                                           asp-route-productId="@item.Id"
                                           class="btn btn-sm btn-info">
                                            <i class="bi bi-images"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @* MOBİL KARTLAR *@
            <div class="d-lg-none" id="sortable-products-mobile">
                @foreach (var item in Model)
                {
                    <div class="card mb-2 border" data-id="@item.Id">
                        <div class="card-body p-3">
                            <div class="d-flex gap-3 align-items-start">

                                @* Resim *@
                                <div style="flex-shrink:0;">
                                    @if (!string.IsNullOrEmpty(item.MainImageThumbPath))
                                    {
                                        <img src="@item.MainImageThumbPath" alt="Ürün Resmi"
                                             style="width:60px;height:60px;object-fit:cover;border-radius:6px;" />
                                    }
                                    else
                                    {
                                        <div style="width:60px;height:60px;border-radius:6px;background:#f0f0f0;display:flex;align-items:center;justify-content:center;">
                                            <i class="bi bi-image text-muted"></i>
                                        </div>
                                    }
                                </div>

                                @* Bilgiler *@
                                <div style="flex:1;min-width:0;">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <p class="fw-semibold mb-0" style="font-size:14px;">@item.ProductName</p>
                                            <p class="text-muted mb-1" style="font-size:12px;">@item.ProductCode</p>
                                        </div>
                                        <span class="drag-handle text-muted ms-2" style="cursor:grab;">☰</span>
                                    </div>

                                    <div class="d-flex flex-wrap gap-1 mb-2">
                                        <span class="badge bg-primary" style="font-size:11px;">
                                            @item.UnitPrice.ToString("N2", new System.Globalization.CultureInfo("tr-TR")) @item.CurrencyCode
                                        </span>
                                        @if (item.StockAmount <= 0)
                                        {
                                            <span class="badge bg-danger" style="font-size:11px;">Stok: @item.StockAmount</span>
                                        }
                                        else if (item.StockAmount <= 5)
                                        {
                                            <span class="badge bg-warning text-dark" style="font-size:11px;">Stok: @item.StockAmount</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success" style="font-size:11px;">Stok: @item.StockAmount</span>
                                        }
                                        @if (item.AvailableForSale)
                                        {
                                            <span class="badge bg-success" style="font-size:11px;">Satışta</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary" style="font-size:11px;">Pasif</span>
                                        }
                                        <span class="badge bg-light text-dark border" style="font-size:11px;">
                                            <i class="bi bi-images"></i> @item.ImageCount resim
                                        </span>
                                    </div>

                                    <div class="d-flex gap-1">
                                        <a asp-action="Edit" asp-route-id="@item.Id"
                                           class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        @if (item.ImageCount > 0)
                                        {
                                            <button class="btn btn-sm btn-danger" disabled>
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        }
                                        else
                                        {
                                            <a asp-action="Delete" asp-route-id="@item.Id"
                                               class="btn btn-sm btn-danger">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                        <a asp-controller="ProductImage" asp-action="Index"
                                           asp-route-productId="@item.Id"
                                           class="btn btn-sm btn-info">
                                            <i class="bi bi-images"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
    <script src="~/js/product-order.js"></script>

}