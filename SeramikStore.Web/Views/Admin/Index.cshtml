@{
    ViewData["Title"] = "Yönetim Paneli";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var fullName = Context.Session.GetString("session_UserFullName");
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-body">

            <h5 class="mb-4">
                <i class="bi bi-speedometer2 me-2"></i>
                Yönetim Paneli
            </h5>

            <p class="text-muted mb-4">Merhaba, <strong>@fullName</strong></p>

            <div class="row g-3">

                <div class="col-6 col-md-4">
                    <a asp-controller="Order" asp-action="CustomerOrders" class="text-decoration-none">
                        <div class="card h-100 border border-primary">
                            <div class="card-body d-flex flex-column gap-2 position-relative">
                                <span class="badge bg-primary position-absolute top-0 end-0 m-2">Öncelikli</span>
                                <div class="rounded p-2" style="width:40px;height:40px;display:flex;align-items:center;justify-content:center;background:rgba(13,110,253,0.1);">
                                    <i class="bi bi-cart-check fs-5 text-primary"></i>
                                </div>
                                <div>
                                    <p class="fw-semibold mb-1">Müşteri Siparişleri</p>
                                    <p class="text-muted small mb-0">Siparişleri görüntüle ve yönet</p>
                                </div>
                                <span class="text-primary small">Görüntüle →</span>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-6 col-md-4">
                    <a asp-controller="Product" asp-action="Index" class="text-decoration-none">
                        <div class="card h-100 border">
                            <div class="card-body d-flex flex-column gap-2">
                                <div class="rounded p-2 bg-light" style="width:40px;height:40px;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-box-seam fs-5 text-secondary"></i>
                                </div>
                                <div>
                                    <p class="fw-semibold mb-1">Ürün Tanımlama</p>
                                    <p class="text-muted small mb-0">Ürün ekle, düzenle, sırala</p>
                                </div>
                                <span class="text-muted small">Yönet →</span>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-6 col-md-4">
                    <a asp-controller="Currency" class="text-decoration-none">
                        <div class="card h-100 border">
                            <div class="card-body d-flex flex-column gap-2">
                                <div class="rounded p-2 bg-light" style="width:40px;height:40px;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-currency-exchange fs-5 text-secondary"></i>
                                </div>
                                <div>
                                    <p class="fw-semibold mb-1">Para Birimleri</p>
                                    <p class="text-muted small mb-0">Kur ve döviz ayarları</p>
                                </div>
                                <span class="text-muted small">Yönet →</span>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-6 col-md-4">
                    <a asp-controller="Category" asp-action="Index" class="text-decoration-none">
                        <div class="card h-100 border">
                            <div class="card-body d-flex flex-column gap-2">
                                <div class="rounded p-2 bg-light" style="width:40px;height:40px;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-grid fs-5 text-secondary"></i>
                                </div>
                                <div>
                                    <p class="fw-semibold mb-1">Kategoriler</p>
                                    <p class="text-muted small mb-0">Kategori ekle ve düzenle</p>
                                </div>
                                <span class="text-muted small">Yönet →</span>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-6 col-md-4">
                    <a asp-controller="Reason" asp-action="Index" class="text-decoration-none">
                        <div class="card h-100 border">
                            <div class="card-body d-flex flex-column gap-2">
                                <div class="rounded p-2 bg-light" style="width:40px;height:40px;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-clipboard-check fs-5 text-secondary"></i>
                                </div>
                                <div>
                                    <p class="fw-semibold mb-1">İade Sebepleri</p>
                                    <p class="text-muted small mb-0">İade nedenlerini yönet</p>
                                </div>
                                <span class="text-muted small">Yönet →</span>
                            </div>
                        </div>
                    </a>
                </div>

                <div class="col-6 col-md-4">
                    <a asp-controller="Admin" asp-action="AppLogs" class="text-decoration-none">
                        <div class="card h-100 border">
                            <div class="card-body d-flex flex-column gap-2">
                                <div class="rounded p-2 bg-light" style="width:40px;height:40px;display:flex;align-items:center;justify-content:center;">
                                    <i class="bi bi-journal-text fs-5 text-secondary"></i>
                                </div>
                                <div>
                                    <p class="fw-semibold mb-1">Uygulama Logları</p>
                                    <p class="text-muted small mb-0">Hata ve işlem kayıtları</p>
                                </div>
                                <span class="text-muted small">Görüntüle →</span>
                            </div>
                        </div>
                    </a>
                </div>

            </div>

            <div class="mt-4 d-flex flex-wrap gap-2">
                <button id="btnEnableNotifications" class="btn btn-warning">
                    <i class="bi bi-bell me-1"></i> Bildirimleri Etkinleştir
                </button>
                <button id="btnTestNotification" class="btn btn-outline-primary">
                    <i class="bi bi-bell-fill me-1"></i> Test Bildirimi Gönder
                </button>
                <button id="btnTestEmail" class="btn btn-outline-info">
                    <i class="bi bi-envelope me-1"></i> Test Email Gönder
                </button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-house me-1"></i> Ana Sayfa
                </a>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.7.0/firebase-app.js";
        import { getMessaging, getToken, onMessage }
          from "https://www.gstatic.com/firebasejs/10.7.0/firebase-messaging.js";

        const app = initializeApp({
            apiKey: "AIzaSyCQkw2a1l3JFnwGrvtlhHqDimRR8BYCaSs",
            projectId: "dibuceramic-notifications",
            messagingSenderId: "151007975605",
            appId: "1:151007975605:web:eb9121c3783caaad8646fc"
        });

        const messaging = getMessaging(app);

        onMessage(messaging, (payload) => {
            navigator.serviceWorker.ready.then((registration) => {
                registration.showNotification(payload.notification.title, {
                    body: payload.notification.body,
                    icon: '/images/logo/logowebp.webp'
                });
            });
        });
        async function requestPermission() {
            try {
                const registration = await navigator.serviceWorker.register('/firebase-messaging-sw.js');
                await navigator.serviceWorker.ready;

                // İzin zaten varsa tekrar sorma, direkt token al
                let permission = Notification.permission;
                if (permission !== 'granted') {
                    permission = await Notification.requestPermission();
                }

                if (permission === 'granted') {
                    const token = await getToken(messaging, {
                        vapidKey: 'BJdbWrpDBV1fHd-HRq-GBBiA36oDOLoqRIPlYt2GQC77g-ebW2-0j1Pp7btuJB5yaBd8fCFS5Qr7upYjO_9sOTI',
                        serviceWorkerRegistration: registration
                    });

                        await fetch('/Product/SaveFcmToken', {
                            method: 'POST',
                            body: JSON.stringify({
                                token,
                                userAgent: navigator.userAgent,
                                deviceName: getDeviceName()
                            }),
                            headers: { 'Content-Type': 'application/json' }
                        });

                    document.getElementById('btnEnableNotifications').innerHTML =
                        '<i class="bi bi-bell-fill me-1"></i> Bildirimler Aktif ✅';
                    document.getElementById('btnEnableNotifications').classList.replace('btn-warning', 'btn-success');
                } else {
                    alert("Bildirim izni verilmedi.");
                }
            } catch (err) {
                alert("Hata: " + err.message);
            }
        }


        document.getElementById('btnEnableNotifications')
            .addEventListener('click', requestPermission);

        // Sayfa açılınca izin zaten verilmişse butonu güncelle
        if (Notification.permission === 'granted') {
            document.getElementById('btnEnableNotifications').innerHTML =
                '<i class="bi bi-bell-fill me-1"></i> Bildirimler Aktif ✅';
            document.getElementById('btnEnableNotifications').classList.replace('btn-warning', 'btn-success');
            // disabled KALDIRILDI — tekrar basılabilsin, token yenilensin
        }


           function getDeviceName() {
            const ua = navigator.userAgent;
            if (/iPhone/.test(ua)) return 'iPhone';
            if (/iPad/.test(ua)) return 'iPad';
            if (/Android/.test(ua)) {
                const match = ua.match(/Android.*?;\s*([^)]+)\)/);
                return match ? match[1].trim() : 'Android';
            }
            if (/Windows/.test(ua)) return 'Windows PC';
            if (/Macintosh/.test(ua)) return 'Mac';
            return 'Bilinmeyen';
        }

                // Test Bildirimi
        document.getElementById('btnTestNotification').addEventListener('click', async () => {
            const btn = document.getElementById('btnTestNotification');
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass me-1"></i> Gönderiliyor...';
            try {
                const response = await fetch('/Admin/TestNotification', { method: 'POST' });
                const result = await response.json();
                if (result.success) {
                    btn.innerHTML = '<i class="bi bi-check-circle me-1"></i> Gönderildi ✅';
                    btn.classList.replace('btn-outline-primary', 'btn-success');
                } else {
                    btn.innerHTML = '<i class="bi bi-x-circle me-1"></i> Hata ❌';
                    btn.classList.replace('btn-outline-primary', 'btn-danger');
                    alert("Hata: " + result.message);
                }
            } catch (err) {
                btn.innerHTML = '<i class="bi bi-x-circle me-1"></i> Hata ❌';
                alert("Hata: " + err.message);
            } finally {
                setTimeout(() => {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-bell-fill me-1"></i> Test Bildirimi Gönder';
                    btn.className = 'btn btn-outline-primary';
                }, 3000);
            }
        });

        // Test Email
        document.getElementById('btnTestEmail').addEventListener('click', async () => {
            const btn = document.getElementById('btnTestEmail');
            btn.disabled = true;
            btn.innerHTML = '<i class="bi bi-hourglass me-1"></i> Gönderiliyor...';
            try {
                const response = await fetch('/Admin/TestEmail', { method: 'POST' });
                const result = await response.json();
                if (result.success) {
                    btn.innerHTML = '<i class="bi bi-check-circle me-1"></i> Gönderildi ✅';
                    btn.classList.replace('btn-outline-info', 'btn-success');
                } else {
                    btn.innerHTML = '<i class="bi bi-x-circle me-1"></i> Hata ❌';
                    btn.classList.replace('btn-outline-info', 'btn-danger');
                    alert("Hata: " + result.message);
                }
            } catch (err) {
                btn.innerHTML = '<i class="bi bi-x-circle me-1"></i> Hata ❌';
                alert("Hata: " + err.message);
            } finally {
                setTimeout(() => {
                    btn.disabled = false;
                    btn.innerHTML = '<i class="bi bi-envelope me-1"></i> Test Email Gönder';
                    btn.className = 'btn btn-outline-info';
                }, 3000);
            }
        });

    </script>
}