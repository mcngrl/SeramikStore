@using Microsoft.Extensions.Localization
@using SeramikStore.Web.Localization
@model SeramikStore.Services.DTOs.CartResultDto
@inject IStringLocalizer<CartResource> L
@using System.Globalization

@{
    ViewData["Title"] = L["Sepetim"];
    var culture = CultureInfo.CurrentCulture;
    var araToplam = Model.Summary.TotalAmount;
    var kargo = Model.Summary.CargoAmount;
    var toplam = Model.Summary.GrandTotal;
    var CurrencyCode = Model.Summary.CurrencyCode.ToString().ToUpper();
}

<div class="container mt-8">

    @* BAŞLIK küçültüldü: h4 → h6, mb-3 → mb-2 *@
    <h6 class="mb-2 fw-semibold">
        @L["Sepetim"] (@Model.Items.Sum(x => x.Quantity) @L["Ürün"])
    </h6>

    <div class="row">
        <!-- SOL TARAF : SEPET LİSTESİ -->
        <div class="col-md-8">
            @foreach (var item in Model.Items)
            {
                <div class="row align-items-center border rounded-4 p-2 product-box">

                    <div class="col-3 col-md-2 product-image">
                        <img src="@(string.IsNullOrEmpty(item.MainImageThumbPath) ? "/images/no-image.png" : item.MainImageThumbPath)"
                             class="img-fluid"
                             alt="@item.ProductName" />
                    </div>



                    <!-- Ürün Bilgi -->
                    <div class="col-9 col-md-5">
                        <div class="fw-semibold text-dark">
                            @item.ProductName
                        </div>
                        <div class="text-muted small">
                            @L["Ürün Kodu"]: @item.ProductCode
                        </div>

                        @* Stok durumu *@
                        @if (item.StockAmount <= 0)
                        {
                            <span class="badge bg-danger" style="font-size:0.65rem;">@L"Tükendi"]</span>
                        }
                        else if (item.StockAmount <= 5)
                        {
                            <span class="badge bg-warning text-dark" style="font-size:0.65rem;">@L["Son"] @item.StockAmount @L["adet"]</span>
                        }
                        else
                        {
                            <span class="badge bg-success" style="font-size:0.65rem;"> @L["Stokta"] @item.StockAmount @L["adet"]</span>
                        }
                    </div>
 

                    <div class="col-6 col-md-2 text-md-center mt-2 mt-md-0">
                        <div class="d-flex align-items-center justify-content-md-center gap-1">
                            <a asp-action="Decrease" asp-route-id="@item.Id" class="btn btn-light btn-sm px-2">−</a>
                            <span class="mx-1 small">@item.Quantity @L["Adet"]</span>
                           @*  <a asp-action="Increase" asp-route-id="@item.Id" class="btn btn-light btn-sm px-2">+</a> *@
                            @if (item.Quantity >= item.StockAmount)
                            {
                                <button class="btn btn-light btn-sm px-2" disabled title="Maksimum stok adedine ulaşıldı">+</button>
                            }
                            else
                            {
                                <a asp-action="Increase" asp-route-id="@item.Id"
                                   class="btn btn-light btn-sm px-2">+</a>
                            }
                        </div>
                    </div>

                    @* FİYAT küçültüldü: fw-bold → fw-semibold small *@
                    <div class="col-4 col-md-2 text-end mt-2 mt-md-0">
                        <div class="fw-semibold small">
                            @item.LineTotal.ToString("N2", culture)
                            @item.CurrencyCode.ToString().ToUpper()
                        </div>
                    </div>

                    <!-- Sil -->
                    <div class="col-2 col-md-1 text-end mt-2 mt-md-0">
                        <a asp-action="DeleteCartItem"
                           asp-route-id="@item.Id"
                           class="text-muted small text-decoration-none">
                            <i class="fa-regular fa-trash-alt"></i>
                        </a>
                    </div>

                </div>
            }
        </div>

        @* SİPARİŞ ÖZETİ KARTI küçültüldü *@
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-body p-3">

                    @* Başlık: h5 → h6 *@
                    <h6 class="mb-2 fw-semibold">@L["Sipariş Özeti"]</h6>

                    <div class="d-flex justify-content-between mb-1 small">
                        <span class="text-muted">@L["Sipariş Tutarı"]</span>
                        <span>@araToplam.ToString("N2", culture) @CurrencyCode</span>
                    </div>

                    <div class="d-flex justify-content-between mb-2 small">
                        <span class="text-muted">@L["Kargo Tutarı"]</span>
                        <span>@kargo.ToString("N2", culture) @CurrencyCode</span>
                    </div>

                    <hr class="my-2" />

                    @* Toplam: fs-5 → fs-6 *@
                    <div class="d-flex justify-content-between fw-bold" style="font-size:0.95rem;">
                        <span>@L["Toplam Tutar"]</span>
                        <span>@toplam.ToString("N2", culture) @CurrencyCode</span>
                    </div>

                    <a asp-controller="Cart"
                       asp-action="AddressDetail"
                       class="btn btn-warning w-100 mt-3 @(Model.Items.Any() ? "" : "disabled")"
                       tabindex="@(Model.Items.Any() ? "0" : "-1")"
                       aria-disabled="@(Model.Items.Any() ? "false" : "true")">
                        @L["Alışverişi Tamamla"]
                    </a>

                </div>
            </div>
        </div>

    </div>
</div>

<style>
    .product-image img {
        width: 90px;
        height: 90px;
        object-fit: contain;
    }
</style>