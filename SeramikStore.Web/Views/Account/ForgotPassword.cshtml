
@using SeramikStore.Web.Localization
@inject IStringLocalizer<AccountResource> L
@using SeramikStore.Web.ViewModels
@model ForgotPasswordViewModel


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            <div class="card shadow-lg rounded-3">
                <div class="card-body p-4">

                    <!-- HEADER -->
                    <h4 class="mb-4">@L["Şifre Sıfırlama"]</h4>

                    <!-- FORM -->
                    <form method="post">
                        <div class="mb-3 text-start">
                            <label class="form-label">@L["Email"]</label>
                            <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <button class="btn btn-primary w-100">
                            @L["Şifre Sıfırlama Linki Gönder"]
                        </button>
                    </form>

                    <!-- FOOTER -->
                    <div class="mt-4 text-muted small">
                        @L["Lütfen kayıtlı email adresinizi girin."]
                    </div>

                </div>
            </div>

        </div>
    </div>
</div>