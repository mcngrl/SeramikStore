@using SeramikStore.Web.Localization
@using SeramikStore.Web.ViewModels
@model VerifyEmailViewModel
@inject IStringLocalizer<AccountResource> L

@{
    ViewData["Title"] = "Email Doğrula";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-2">
            <partial name="_LeftMenu" />
        </div>

        <div class="col-md-7">
            <div class="card shadow-sm">
                <div class="card-body">

                    <h5 class="mb-3">Email Adresi Doğrulama</h5>

                    <div class="alert alert-info">
                        @Model.Email adresine gönderilen 6 haneli kodu giriniz.
                    </div>

                    <form asp-action="VerifyEmailCode" asp-controller="Account" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
   
                            <input hidden asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Doğrulama Kodu</label>
                            <input asp-for="Code" class="form-control" placeholder="6 haneli kod" maxlength="6" />
                            <span asp-validation-for="Code" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-success w-100">
                            Gönder
                        </button>
                    </form>

                    <hr />

                    <form asp-action="ResendConfirmationEmail2" method="post">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-link">
                            Kodu tekrar gönder
                        </button>
                    </form>

                    <a asp-action="Profile" class="btn btn-link">
                        Email adresini değiştir
                    </a>

                </div>
            </div>
        </div>

        <div class="col-md-3"></div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}