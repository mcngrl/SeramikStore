@using Microsoft.Extensions.Localization
@using SeramikStore.Web.Localization
@inject IStringLocalizer<AccountResource> L
@using SeramikStore.Web.ViewModels
@model LoginViewModel
@{
    ViewData["Title"] = L["Giriş Yap"];
}




    <div class="container mt-5 d-flex align-items-center justify-content-center">
        <div class="row w-100 justify-content-center">
            <div class="col-md-5 col-sm-8">
                <div class="card shadow-lg border-0">
                    <div class="card-header text-center bg-primary text-white">
                        <h6 class="mb-0">@L["Üye Girişi"]</h6>
                    </div>
                    <form asp-action="Login" method="post">
                        <div class="card-body p-4">
                            <div class="form-group mb-3">
                                <label>@L["Email"]</label>
                                <input asp-for="UserName" class="form-control" placeholder="@L["E-Posta Adresiniz"]" />
                                <span asp-validation-for="UserName" class="text-danger"></span>
                            </div>

@*                             <div class="form-group mb-3">
                                <label>@L["Şifre"]</label>
                                <input asp-for="Password" type="password" class="form-control" placeholder="@L["Şifreniz"]"/>
                                <span asp-validation-for="Password" class="text-danger"></span>
                            </div> *@

                        <div class="form-group mb-3">
                            <label>@L["Şifre"]</label>
                            <div class="input-group">
                                <input asp-for="Password" type="password" class="form-control"
                                       placeholder="@L["Şifreniz"]" id="loginPasswordInput" />
                                <button class="btn btn-outline-secondary" type="button"
                                        tabindex="-1" id="toggleLoginPassword">
                                    <i class="bi bi-eye" id="toggleLoginPasswordIcon"></i>
                                </button>
                            </div>
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                            <div class="form-group form-check mb-3">
                                <input asp-for="RememberMe" class="form-check-input" />
                                <label asp-for="RememberMe" class="form-check-label">
                                    @L["Beni Hatırla"]
                                </label>
                            </div>

                            <button type="submit" class="btn btn-primary w-100">
                                <i class="fas fa-sign-in-alt"></i>@L["Giriş Yap"]
                            </button>
                       
                        </div>
                    </form>
                    @{
                        var emailError = ViewData.ModelState["emaildogrulama"]?.Errors.FirstOrDefault();
                    }

                    @if (emailError != null)
                    {
                        <div class="alert alert-warning">
                            @emailError.ErrorMessage

                            <br />
                            <small>
                                @L["Doğrulama emaili elinize geçmedi mi?"]
                                <form asp-action="ResendConfirmationEmail" asp-controller="Account" method="post">
                                    <input type="hidden" name="Email" value="@Model.UserName" />
                                    <button type="submit" class="btn btn-link">@L["Doğrulama emailini tekrar gönder"]</button>
                                </form>
                            </small>
                        </div>
                    }

                    @{
                        var userorpassError = ViewData.ModelState["kullanicisifrehatasi"]?.Errors.FirstOrDefault();
                    }

                    @if (userorpassError != null)
                    {
                        <div class="alert alert-warning">
                            @userorpassError.ErrorMessage
                        </div>
                    }


                    <div class="card-footer text-center">
                        <small>
                            @L["Hesabın yok mu?"]
                            <a asp-action="Register" asp-controller="Account">@L["Kayıt Ol"]</a>
                        </small>
                    </div>
                    <div class="card-footer text-center">
                        <a asp-action="ForgotPassword" asp-controller="Account">
                            @L["Şifremi Unuttum"]
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        function setupHoldToView(buttonId, inputId, iconId) {
            const btn   = document.getElementById(buttonId);
            const input = document.getElementById(inputId);
            const icon  = document.getElementById(iconId);

            function show() { input.type = "text";     icon.className = "bi bi-eye-slash"; }
            function hide() { input.type = "password"; icon.className = "bi bi-eye"; }

            btn.addEventListener("mousedown",  show);
            btn.addEventListener("mouseup",    hide);
            btn.addEventListener("mouseleave", hide);

            btn.addEventListener("touchstart",  (e) => { e.preventDefault(); show(); });
            btn.addEventListener("touchend",    hide);
            btn.addEventListener("touchcancel", hide);
        }

        setupHoldToView("toggleLoginPassword", "loginPasswordInput", "toggleLoginPasswordIcon");
    </script>
}